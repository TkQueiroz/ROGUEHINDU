function updateEffects(dt){
  for(let i=effects.length-1;i>=0;i--){
    const fx = effects[i];
    fx.life -= dt;
    if(fx.type==="arcSlash" || fx.type==="ringSlash"){ if(fx.life<=0) effects.splice(i,1); continue; }
    if(fx.type==="bladeStorm"){
      fx.x = player.x; fx.y = player.y;
      fx.pulseTimer -= dt;
      if(fx.pulseTimer<=0 && fx.pulsesLeft>0){
        fx.pulseTimer = fx.pulseInterval; fx.pulsesLeft--;
        for(let j=enemies.length-1;j>=0;j--){
          if(dist2(enemies[j], player) < fx.radius**2){
            if(enemies[j].isBoss && enemies[j].invulnerable) continue; 
            enemies[j].hp -= fx.damagePerPulse;
            applyHitEffects(enemies[j], j, fx.damagePerPulse);
            if(enemies[j].hp<=0) toKill.push(j);
          }
        }
        spawnParticles(player.x,player.y,fx.color,20);
        SoundManager.play('hitEnemy');
      }
      if(fx.life<=0) effects.splice(i,1); continue;
    }
    if(fx.type==="shockwave"){
      if(fx.startDelay>0){ fx.startDelay-=dt; continue; }
      fx.radius += fx.speed*dt;
      for(let j=enemies.length-1;j>=0;j--){
        const e = enemies[j];
        if(fx.hit.has(e)) continue;
        const d = Math.hypot(e.x-fx.x, e.y-fx.y);
        if(Math.abs(d-fx.radius) < fx.thickness/2 + e.r){
          if(e.isBoss && e.invulnerable) continue;
          e.hp -= fx.damage;
          applyHitEffects(e,j,fx.damage);
          fx.hit.add(e);
          if(e.hp<=0) toKill.push(j);
        }
      }
      if(fx.radius>=fx.maxRadius || fx.life<=0) effects.splice(i,1); continue;
    }
    if(fx.type==="bossShockwave"){
      fx.radius += fx.speed*dt;
      let inGap = false;
  if (fx.gapArc > 0) {
    const angleToPlayer = Math.atan2(player.y - fx.y, player.x - fx.x);
    const diff = normalizeAngle(angleToPlayer - fx.gapAngle);
    if (Math.abs(diff) < fx.gapArc / 2) inGap = true;
  }
      if(!inGap && !fx.hit.has("player") && Math.abs(Math.hypot(player.x-fx.x, player.y-fx.y)-fx.radius) < fx.thickness/2 + player.r){
        if(!player.invincible && player.hurtTimer<=0){
          if(player.shield){ player.shield=false; spawnParticles(player.x,player.y,"#3F51B5",20); }
          else{ player.hp -= fx.damage; player.hurtTimer = 0.7; SoundManager.play('playerHurt'); spawnParticles(player.x,player.y,"#FF1744",12); }
          if(player.hp<=0) gameOver();
        }
        fx.hit.add("player");
      }
      if(fx.radius>=fx.maxRadius || fx.life<=0) effects.splice(i,1); continue;
    }
    if(fx.type==="arrowRain"){
      fx.arrowTimer -= dt;
      if(fx.arrowTimer<=0){
        fx.arrowTimer = fx.arrowInterval;
        const a = Math.random()*Math.PI*2;
        const r = Math.sqrt(Math.random())*fx.radius;
        const ax = fx.x+Math.cos(a)*r, ay = fx.y+Math.sin(a)*r;
        effects.push({ type:"fallingArrow", x:ax, y:ay, startY:ay-300,
          life:0.35, maxLife:0.35, color:selectedWeapon?selectedWeapon.color:"#FFAA00",
          damage:fx.damage, impacted:false });
      }
      if(fx.life<=0) effects.splice(i,1); continue;
    }
    if(fx.type==="fallingArrow"){
      if(!fx.impacted && fx.life < fx.maxLife*0.3){
        fx.impacted = true;
        for(let j=enemies.length-1;j>=0;j--){
          if(dist2(enemies[j], fx) < (25+enemies[j].r)**2){
            if(enemies[j].isBoss && enemies[j].invulnerable) continue; 
            enemies[j].hp -= fx.damage;
            applyHitEffects(enemies[j], j, fx.damage);
            if(enemies[j].hp<=0) toKill.push(j);
          }
        }
        spawnParticles(fx.x,fx.y,fx.color,8);
      }
      if(fx.life<=0) effects.splice(i,1); continue;
    }
    if(fx.type==="divineSpear"){
      if(!fx.damaged){
        fx.damaged = true;
        const cA=Math.cos(fx.angle), sA=Math.sin(fx.angle);
        for(let j=enemies.length-1;j>=0;j--){
          const e=enemies[j];
          const dx=e.x-fx.x, dy=e.y-fx.y;
          const proj = dx*cA+dy*sA;
          const perp = Math.abs(-dx*sA+dy*cA);
          if(proj>0 && proj<fx.length && perp < fx.width/2+e.r){
          if(e.isBoss && e.invulnerable) continue;
            e.hp -= fx.damage;
            applyHitEffects(e,j,fx.damage);
            if(e.hp<=0) toKill.push(j);
          }
        }
        SoundManager.play('hitEnemy');
      }
      if(fx.life<=0) effects.splice(i,1); continue;
    }
  }
}

