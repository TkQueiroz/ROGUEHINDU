            if(enemies[i].isBoss && enemies[i].invulnerable) continue; 
      enemies[i].hp -= CFG.MELEE_DAMAGE;
      if(enemies[i].hp<=0) toKill.push(i);
    }
  }
  spawnParticles(player.x,player.y,"#FF6600",40);
}

/* ═══════════════════════════════════════════════════════════════════════════
   BOSS — COMPORTAMENTOS
   ═══════════════════════════════════════════════════════════════════════════ */
function shootPattern(pattern, boss, baseAngle, count, speed, color, damage, options={}) {
  const { spread=0, offset=0, homing=false, spiral=false } = options;
  for (let i = 0; i < count; i++) {
    let angle = baseAngle;
    if (spread > 0) angle += (i - (count-1)/2) * spread;
    else if (spiral) angle += i * 0.5;
    else if (count > 1) angle += (i / count) * Math.PI * 2;
    
    const vx = Math.cos(angle) * speed;
    const vy = Math.sin(angle) * speed;
    const bullet = {
      x: boss.x + Math.cos(angle) * (boss.r + offset),
      y: boss.y + Math.sin(angle) * (boss.r + offset),
      vx, vy, r: 10, life: 3.5, damage, color,
      homing: homing ? { target: player, turnRate: 2.5 } : null
    };
    enemyBullets.push(bullet);
  }
}

function createAreaIndicator(x, y, radius, duration, color) {
  effects.push({
    type: "areaIndicator",
    x, y, radius,
    life: duration, maxLife: duration,
    color: color || "#ff0000",
    active: false
  });
}

function updateBossBehavior(boss, dt) {
  boss.bTimer = (boss.bTimer || 0) + dt;
  boss.animFrame = (boss.animFrame || 0) + dt * 4;
  boss.phaseTimer = (boss.phaseTimer || 0) + dt;
  
  const dmgMult = boss.dmgMult * getDifficultyModifiers().dmgMult * getPlayerScaleFactor();
  const hpPercent = boss.hp / boss.maxHp;
  
let phase = 1;
if (boss.phase3Forced) {
  phase = 3; // Força fase 3 se os totens foram destruídos
} else {
  if (hpPercent < 0.3) phase = 3;
  else if (hpPercent < 0.6) phase = 2;
}
boss.currentPhase = phase;
  
  const phaseSpeedMultiplier = phase === 3 ? 1.25 : (phase === 2 ? 1.1 : 1.0);
  
  switch(boss.behavior) {
    
    // ==================== RAVANA (BOSS INICIAL) ====================
    case "spreadShoot": {
      const baseInterval = 2.4 / phaseSpeedMultiplier; // mais lento que antes
      if (boss.bTimer >= baseInterval) {
        boss.bTimer = 0;
        
        // Rajada circular (quantidade equilibrada)
        const bulletCount = phase === 3 ? 18 : (phase === 2 ? 14 : 10);
        const angleOffset = Date.now() * 0.0008;
        for (let i = 0; i < bulletCount; i++) {
          const a = (i / bulletCount) * Math.PI * 2 + angleOffset;
          enemyBullets.push({
            x: boss.x, y: boss.y,
            vx: Math.cos(a) * 190,
            vy: Math.sin(a) * 190,
            r: 9, life: 3.0,
            damage: CFG.ENEMY_DAMAGE * 1.0 * dmgMult,
            color: "#dc2626"
          });
        }
        
        // 3 tiros direcionados (fase 2+)
        if (phase >= 2) {
           const shotCount = difficulty === "easy" ? 2 : (difficulty === "hard" ? 5 : 3);
          const spreadAngle = 0.22;   // ângulo entre cada tiro (ajuste se quiser)
         const baseAngle = Math.atan2(player.y - boss.y, player.x - boss.x);
  for (let i = 0; i < shotCount; i++) {
    const offset = (i - (shotCount - 1) / 2) * spreadAngle;
    const a = baseAngle + offset;
    enemyBullets.push({
      x: boss.x, y: boss.y,
      vx: Math.cos(a) * 210,
      vy: Math.sin(a) * 210,
      r: 8, life: 2.5,
      damage: CFG.ENEMY_DAMAGE * 0.9 * dmgMult,
      color: "#ff8888"
    });
  }
        }
        
        // Spawn de minion pequeno (fase 3, chance baixa)
        const spawnChance=difficulty==="easy" ? 0.3 : difficulty==="hard" ? 0.7 : 0.5; 
        if (phase === 3 && Math.random() < spawnChance) {
          const a = Math.random() * Math.PI * 2;
          const r = 90;
          // Indicador visual antes de spawnar
          const spawnX = boss.x + Math.cos(a)*r;
          const spawnY = boss.y + Math.sin(a)*r;
          createAreaIndicator(spawnX, spawnY, 25, 0.8, "#ffaa00");
          setTimeout(() => {
            spawnMinion(spawnX, spawnY, "Rakshasa"); // minion fraco e pequeno
          }, 600);
        }
        
        SoundManager.play('special');
        triggerShake(0.2, 5);
      }
      break;
    }
    
    // ==================== GANESHA (INTERMEDIÁRIO) ====================
   case "slamShockwave": {
  // Intervalo base ajustado por dificuldade
  const baseInterval = 
    difficulty === "easy" ? 5.0 : 
    difficulty === "hard" ? 3.5 : 
    4.5; // normal

  const phaseInterval = baseInterval / phaseSpeedMultiplier;
  
  if (boss.bTimer >= phaseInterval) {
    boss.bTimer = 0;

    const isEasy = difficulty === "easy";
    const isHard = difficulty === "hard";

    // Alcance total da arena
    const maxR1 = 3000;
    const maxR2 = 3000;

    let speed1, speed2, life1, life2;
    let gapArc = 0, gapAngle = 0;

    if (isEasy) {
  speed1 = 340; life1 = maxR1 / speed1;
  speed2 = 280; life2 = maxR2 / speed2;
  gapArc = Math.PI / 3;
  gapAngle = Math.atan2(player.y - boss.y, player.x - boss.x) + Math.PI/2.765;
    } else if (isHard) {
      speed1 = 480; life1 = maxR1 / speed1;
      speed2 = 380; life2 = maxR2 / speed2;
    } else { // normal
      speed1 = 260; life1 = maxR1 / speed1;  // ~11.5s para atravessar
      speed2 = 210; life2 = maxR2 / speed2;  // ~14.3s
    }

    effects.push({
      type: "bossShockwave",
      x: boss.x, y: boss.y,
      radius: 0, maxRadius: maxR1,
      speed: speed1,
      damage: CFG.ENEMY_DAMAGE * 1.2 * dmgMult,
      thickness: 40, hit: new Set(),
      life: life1, maxLife: life1,
      color: "#6b7280",
      gapAngle, gapArc
    });

    effects.push({
      type: "bossShockwave",
      x: boss.x, y: boss.y,
      radius: 0, maxRadius: maxR2,
      speed: speed2,
      damage: CFG.ENEMY_DAMAGE * 0.9 * dmgMult,
      thickness: 30, hit: new Set(),
      life: life2, maxLife: life2,
      color: "#8b5a2b",
      gapAngle, gapArc
    });

    // Indicador visual da brecha no fácil
    if (gapArc > 0) {
      effects.push({
        type: "safeZone",
        x: boss.x, y: boss.y,
        radius: 100,
        angle: gapAngle,
        arc: gapArc,
        life: 1.2, maxLife: 1.2,
        color: "#00ff88"
      });
    }

    // Projéteis em espiral (mantidos)
    if (phase >= 2) {
      for (let i = 0; i < 8; i++) {
        const angle = (i / 8) * Math.PI * 2 + boss.phaseTimer * 0.5;
        enemyBullets.push({
          x: boss.x, y: boss.y,
          vx: Math.cos(angle) * 160,
          vy: Math.sin(angle) * 160,
          r: 7, life: 3.0,
          damage: CFG.ENEMY_DAMAGE * 0.7 * dmgMult,
          color: "#c0a080"
        });
      }
    }

    // Atração na fase 3 (mantida)
    if (phase === 3) {
      const dx = player.x - boss.x;
      const dy = player.y - boss.y;
      const dist = Math.hypot(dx, dy);
      if (dist > 350 && dist < 600) {
        const pull = 120 * dt;
        player.x -= (dx / dist) * pull;
        player.y -= (dy / dist) * pull;
      }
    }

    triggerShake(0.4, 10);
    SoundManager.play('special');
  }

  // Atração contínua na fase 3 (mantida)
  if (phase === 3) {
    const dx = player.x - boss.x;
    const dy = player.y - boss.y;
    const dist = Math.hypot(dx, dy);
    if (dist > 400) {
      const pull = 40 * dt;
      player.x -= (dx / dist) * pull;
      player.y -= (dy / dist) * pull;
    }
  }
  break;
}
    
    // ========== HANUMAN: Macaco Enfurecido ==========
    case "teleportFire": {
      const baseInterval = 2.2 / phaseSpeedMultiplier;
      if (boss.bTimer >= baseInterval) {
        boss.bTimer = 0;
        
        // Teleporte
        const a = Math.random() * Math.PI * 2;
        const r = 260 + Math.random() * 100;
        boss.x = clamp(player.x + Math.cos(a) * r, CFG.WALL_THICKNESS + boss.r, CFG.ARENA_W - CFG.WALL_THICKNESS - boss.r);
        boss.y = clamp(player.y + Math.sin(a) * r, CFG.WALL_THICKNESS + boss.r, CFG.ARENA_H - CFG.WALL_THICKNESS - boss.r);
        spawnParticles(boss.x, boss.y, "#f97316", 40);
        
        // Fireballs em leque
        const baseAngle = Math.atan2(player.y - boss.y, player.x - boss.x);
        const count = phase === 3 ? 5 : (phase === 2 ? 4 : 3);
        for (let i = 0; i < count; i++) {
          const angle = baseAngle + (i - (count-1)/2) * 0.25;
          enemyBullets.push({
            x: boss.x, y: boss.y,
            vx: Math.cos(angle) * 300,
            vy: Math.sin(angle) * 300,
            r: 14, life: 2.5,
            damage: CFG.ENEMY_DAMAGE * 1.3 * dmgMult,
            color: "#f97316",
            fireball: true,
            trail: true // novo: deixa rastro de fogo
          });
        }
        
        // Fase 2+: cria rastro de fogo no chão
        if (phase >= 2) {
          const trailAngle = baseAngle;
          for (let d = 0; d < 300; d += 40) {
            const fx = boss.x + Math.cos(trailAngle) * d;
            const fy = boss.y + Math.sin(trailAngle) * d;
            effects.push({
              type: "fireTrail",
              x: fx, y: fy,
              radius: 30,
              damage: CFG.ENEMY_DAMAGE * 0.5 * dmgMult,
              life: 2.0, maxLife: 2.0,
              color: "#ff6600"
            });
          }
        }
        
        // Fase 3: cria clones ilusórios
        if (phase === 3) {
          boss.clones = boss.clones || [];
          for (let i = 0; i < 2; i++) {
            const cloneAngle = Math.random() * Math.PI * 2;
            const cloneDist = 150;
            const clone = {
              x: boss.x + Math.cos(cloneAngle) * cloneDist,
              y: boss.y + Math.sin(cloneAngle) * cloneDist,
              timer: 5.0,
              shootTimer: 0
            };
            boss.clones.push(clone);
          }
        }
        
        triggerShake(0.2, 6);
      }
      
      // Atualiza clones (fase 3)
      if (boss.clones) {
        for (let i = boss.clones.length - 1; i >= 0; i--) {
          const clone = boss.clones[i];
          clone.timer -= dt;
          if (clone.timer <= 0) {
            boss.clones.splice(i, 1);
            continue;
          }
          clone.shootTimer -= dt;
          if (clone.shootTimer <= 0) {
            clone.shootTimer = 0.8;
            const angle = Math.atan2(player.y - clone.y, player.x - clone.x);
            enemyBullets.push({
              x: clone.x, y: clone.y,
              vx: Math.cos(angle) * 250,
              vy: Math.sin(angle) * 250,
              r: 10, life: 2.0,
              damage: CFG.ENEMY_DAMAGE * 0.7 * dmgMult,
              color: "#ffaa00"
            });
          }
        }
      }
      break;
    }
    
    // ========== MAHISHASURA: Búfalo Demônio ==========
case "charge": {
  if (!boss.chargeState) { boss.chargeState = "idle"; boss.stateTimer = 0; }
  boss.stateTimer += dt;
  
  const chargeSpeed = 440 * (phase === 3 ? 1.4 : 1.0);
  const windupTime = 1.1 / phaseSpeedMultiplier;
  
  // Comportamento cíclico: idle -> preparar carga -> carregar -> idle
  if (boss.chargeState === "idle") {
    // Ataque sísmico periódico (fendas no chão)
    boss.stompTimer = (boss.stompTimer || 0) + dt;
if (boss.stompTimer >= 3.0) {
  boss.stompTimer = 0;
  // Onda de choque sísmica (terremoto) – fácil de entender
  effects.push({
    type: "bossShockwave",
    x: boss.x, y: boss.y,
    radius: 0, maxRadius: 400,
    speed: 300,
    damage: CFG.ENEMY_DAMAGE * 1.0 * dmgMult,
    thickness: 35,
    hit: new Set(),
    life: 1.5, maxLife: 1.5,
    color: "#8B4513"  // marrom terra
  });
  triggerShake(0.3, 6);
  SoundManager.play('special');
}
    
    // Transição para carga
    if (boss.stateTimer >= 4.0) {
      boss.chargeState = "winding";
      boss.stateTimer = 0;
      boss.chargeAngle = Math.atan2(player.y - boss.y, player.x - boss.x);
      
      // Indicador visual de carga (cone vermelho)
      effects.push({
        type: "chargeIndicator",
        x: boss.x, y: boss.y,
        angle: boss.chargeAngle,
        length: 550, width: 90,
        life: windupTime, maxLife: windupTime,
        color: "#ff0000"
      });
      createAreaIndicator(boss.x, boss.y, 55, windupTime, "#ff0000");
    }
  }
  
  if (boss.chargeState === "winding" && boss.stateTimer >= windupTime) {
    boss.chargeState = "charging";
    boss.stateTimer = 0;
    boss.chargeBounces = phase >= 2 ? 2 : 1;
    // Na fase 3, carga dupla: após primeira carga, faz outra
    boss.chargeCount = phase === 3 ? 2 : 1;
    triggerShake(0.5, 12);
    SoundManager.play('dash');
  }
  
  if (boss.chargeState === "charging") {
    // Movimento
    boss.x += Math.cos(boss.chargeAngle) * chargeSpeed * dt;
    boss.y += Math.sin(boss.chargeAngle) * chargeSpeed * dt;
    
    // Dano de contato é aplicado normalmente
    
    // Verifica colisão com paredes
    let bounced = false;
    if (boss.x < CFG.WALL_THICKNESS + boss.r) {
      boss.x = CFG.WALL_THICKNESS + boss.r;
      boss.chargeAngle = Math.PI - boss.chargeAngle;
      bounced = true;
    } else if (boss.x > CFG.ARENA_W - CFG.WALL_THICKNESS - boss.r) {
      boss.x = CFG.ARENA_W - CFG.WALL_THICKNESS - boss.r;
      boss.chargeAngle = -boss.chargeAngle;
      bounced = true;
    }
    if (boss.y < CFG.WALL_THICKNESS + boss.r) {
      boss.y = CFG.WALL_THICKNESS + boss.r;
      boss.chargeAngle = -boss.chargeAngle;
      bounced = true;
    } else if (boss.y > CFG.ARENA_H - CFG.WALL_THICKNESS - boss.r) {
      boss.y = CFG.ARENA_H - CFG.WALL_THICKNESS - boss.r;
      boss.chargeAngle = Math.PI - boss.chargeAngle;
      bounced = true;
    }
    
    if (bounced) {
      boss.chargeBounces--;
      triggerShake(0.4, 10);
      spawnParticles(boss.x, boss.y, "#8b4513", 25);
      if (boss.chargeBounces <= 0) {
        boss.chargeCount--;
        if (boss.chargeCount > 0) {
          // Nova carga imediatamente na fase 3
          boss.chargeState = "winding";
          boss.stateTimer = 0;
          boss.chargeAngle = Math.atan2(player.y - boss.y, player.x - boss.x);
          effects.push({
            type: "chargeIndicator",
            x: boss.x, y: boss.y,
            angle: boss.chargeAngle,
            length: 550, width: 90,
            life: windupTime*0.7, maxLife: windupTime*0.7,
            color: "#ff0000"
          });
        } else {
          boss.chargeState = "idle";
          boss.stateTimer = 0;
        }
      }
    }
    
    // Se passou tempo demais, encerra
    if (boss.stateTimer >= 2.5) {
      boss.chargeCount--;
      if (boss.chargeCount > 0) {
        boss.chargeState = "winding";
        boss.stateTimer = 0;
        boss.chargeAngle = Math.atan2(player.y - boss.y, player.x - boss.x);
        effects.push({
          type: "chargeIndicator",
          x: boss.x, y: boss.y,
          angle: boss.chargeAngle,
          length: 550, width: 90,
          life: windupTime*0.7, maxLife: windupTime*0.7,
          color: "#ff0000"
        });
      } else {
        boss.chargeState = "idle";
        boss.stateTimer = 0;
      }
    }
    
    // Fase 2+: Chifres giratórios durante a carga (projéteis em espiral)
    if (phase >= 2) {
      boss.spiralTimer = (boss.spiralTimer || 0) + dt;
      if (boss.spiralTimer >= 0.07) {
        boss.spiralTimer = 0;
        const angle = boss.chargeAngle + boss.stateTimer * 5;
        enemyBullets.push({
          x: boss.x, y: boss.y,
          vx: Math.cos(angle) * 300,
          vy: Math.sin(angle) * 300,
          r: 9, life: 4.0,
          damage: CFG.ENEMY_DAMAGE * 0.6 * dmgMult,
          color: "#6b7280"
        });
      }
    }
  }
  break;
}

    // ========== HIRANYAKASHIPU: Rei Imortal ==========
    case "summonMinions": {
  // Inicializa estado da batalha
  if (!boss.battlePhase) {
    boss.battlePhase = 1;
    boss.phaseTimer = 0;
    boss.totemsSpawned = false;
    boss.shieldActive = false;
  }

  boss.phaseTimer += dt;
  const phase = boss.currentPhase;
  const dmgMult = boss.dmgMult * getDifficultyModifiers().dmgMult * getPlayerScaleFactor();

  // === FASE 1 (100% - 60%): ARQUITETO DO CAOS ===
  if (phase === 1) {
    const interval = difficulty === "hard" ? 2.5 : 3.0;
    if (boss.bTimer >= interval) {
      boss.bTimer = 0;

      // Rajada circular massiva (20 tiros)
      for (let i = 0; i < 20; i++) {
        const a = (i / 20) * Math.PI * 2 + boss.phaseTimer * 0.3;
        enemyBullets.push({
          x: boss.x, y: boss.y,
          vx: Math.cos(a) * 280,
          vy: Math.sin(a) * 280,
          r: 10, life: 3.5,
          damage: CFG.ENEMY_DAMAGE * 1.1 * dmgMult,
          color: "#eab308"
        });
      }

      // Duas linhas de projéteis giratórios
      for (let k = 0; k < 2; k++) {
        const baseAngle = boss.phaseTimer * 2.0 + k * Math.PI;
        for (let i = 0; i < 6; i++) {
          const angle = baseAngle + i * (Math.PI / 3);
          enemyBullets.push({
            x: boss.x, y: boss.y,
            vx: Math.cos(angle) * 240,
            vy: Math.sin(angle) * 240,
            r: 8, life: 3.0,
            damage: CFG.ENEMY_DAMAGE * 0.9 * dmgMult,
            color: "#ffcc00"
          });
        }
      }

      // Invoca 4 Yakshas
      for (let i = 0; i < 4; i++) {
        const a = Math.random() * Math.PI * 2;
        const r = 120;
        spawnMinion(boss.x + Math.cos(a)*r, boss.y + Math.sin(a)*r, "Yaksha");
      }

      SoundManager.play('special');
      triggerShake(0.3, 6);
    }

    // Movimento: oscila em torno de uma distância
    const dx = player.x - boss.x;
    const dy = player.y - boss.y;
    const dist = Math.hypot(dx, dy);
    const targetDist = 320;
    if (dist > targetDist + 30) {
      boss.x += (dx / dist) * boss.speed * dt;
      boss.y += (dy / dist) * boss.speed * dt;
    } else if (dist < targetDist - 30) {
      boss.x -= (dx / dist) * boss.speed * 0.8 * dt;
      boss.y -= (dy / dist) * boss.speed * 0.8 * dt;
    }
  }

  // === FASE 2 (60% - 30%): ESCUDO DIVINO + BULLET HELL ===
// === FASE 2 (60% - 30%): ESCUDO DIVINO + BULLET HELL DINÂMICO ===
else if (phase === 2) {
  // Inicializa escudo e totens uma única vez
  if (!boss.shieldActive && !boss.totemsSpawned) {
    boss.shieldActive = true;
    boss.totemsSpawned = true;

    // Totens centrais (mais fáceis de alcançar)
    const corners = [
      { x: CFG.ARENA_W * 0.25, y: CFG.ARENA_H * 0.25 },
      { x: CFG.ARENA_W * 0.75, y: CFG.ARENA_H * 0.25 },
      { x: CFG.ARENA_W * 0.25, y: CFG.ARENA_H * 0.75 },
      { x: CFG.ARENA_W * 0.75, y: CFG.ARENA_H * 0.75 }
    ];

    corners.forEach(pos => {
      const totem = {
        x: pos.x, y: pos.y,
        hp: 150, maxHp: 150,
        speed: 0,
        color: "#eab308",
        name: "Totem",
        sprite: "totem",
        behavior: "immobile",
        r: 30,
        hurtTimer: 0, burnTimer: 0, facing: 1, animFrame: 0,
        isTotem: true,
        bossRef: boss
      };
      enemies.push(totem);
      spawnParticles(pos.x, pos.y, "#eab308", 20);
    });

    bossIntroData = {
      title: "ESCUDO DIVINO ATIVADO!",
      name: "DESTRUA OS TOTENS",
      subtitle: "O caos toma forma",
      color: "#eab308"
    };
    bossIntroTimer = 2.5;
  }

  // Boss fica invulnerável enquanto escudo existir
  boss.invulnerable = boss.shieldActive;

  // Ataque contínuo – a cada 0.6s uma nova "onda" de projéteis
  boss.attackTimer = (boss.attackTimer || 0) + dt;
  const attackInterval = 0.5;
  if (boss.attackTimer >= attackInterval) {
    boss.attackTimer = 0;

    // 1. Projéteis que surgem das BORDAS (como Hanuman, mas mais caóticos)
    const edgeSpawns = 9;
    for (let i = 0; i < edgeSpawns; i++) {
      // Escolhe uma borda aleatória e uma posição ao longo dela
      const side = Math.floor(Math.random() * 4); // 0: top, 1: right, 2: bottom, 3: left
      let sx, sy;
      if (side === 0) { // topo
        sx = Math.random() * CFG.ARENA_W;
        sy = 0;
      } else if (side === 1) { // direita
        sx = CFG.ARENA_W;
        sy = Math.random() * CFG.ARENA_H;
      } else if (side === 2) { // baixo
        sx = Math.random() * CFG.ARENA_W;
        sy = CFG.ARENA_H;
      } else { // esquerda
        sx = 0;
        sy = Math.random() * CFG.ARENA_H;
      }
      // Mira em direção ao jogador com alguma dispersão
      const angle = Math.atan2(player.y - sy, player.x - sx) + (Math.random() - 0.5) * 0.8;
      const speed = 220 + Math.random() * 60;
      enemyBullets.push({
        x: sx, y: sy,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        r: 9, life: 6.0, // vida longa o suficiente para atravessar a arena
        damage: CFG.ENEMY_DAMAGE * 0.8 * dmgMult,
        color: "#ffaa00"
      });
    }

    // 2. Projéteis "varredores" que se movem em linha reta de um lado a outro
    const sweeps = 5;
    for (let i = 0; i < sweeps; i++) {
      // Começa em um ponto aleatório em uma borda e vai para a borda oposta
      const fromSide = Math.floor(Math.random() * 4);
      let startX, startY, angle;
      if (fromSide === 0) {
        startX = Math.random() * CFG.ARENA_W;
        startY = 0;
        angle = Math.PI / 2; // para baixo
      } else if (fromSide === 1) {
        startX = CFG.ARENA_W;
        startY = Math.random() * CFG.ARENA_H;
        angle = Math.PI; // para esquerda
      } else if (fromSide === 2) {
        startX = Math.random() * CFG.ARENA_W;
        startY = CFG.ARENA_H;
        angle = -Math.PI / 2; // para cima
      } else {
        startX = 0;
        startY = Math.random() * CFG.ARENA_H;
        angle = 0; // para direita
      }
      // Varia um pouco o ângulo para não ser perfeitamente reto
      angle += (Math.random() - 0.5) * 0.5;
      const speed = 180 + Math.random() * 70;
      enemyBullets.push({
        x: startX, y: startY,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        r: 12, life: 7.0,
        damage: CFG.ENEMY_DAMAGE * 1.0 * dmgMult,
        color: "#eab308"
      });
    }

    // 3. Pequeno ataque do boss só para manter pressão (4 tiros em leque)
    const baseAngle = Math.atan2(player.y - boss.y, player.x - boss.x);
    for (let i = -1; i <= 1; i += 2) {
      const a = baseAngle + i * 0.4;
      enemyBullets.push({
        x: boss.x, y: boss.y,
        vx: Math.cos(a) * 240,
        vy: Math.sin(a) * 240,
        r: 8, life: 3.0,
        damage: CFG.ENEMY_DAMAGE * 0.7 * dmgMult,
        color: "#ffcc00"
      });
    }

    SoundManager.play('special');
  }

  // Verifica se todos os totens foram destruídos
  const totemsAlive = enemies.filter(e => e.isTotem && e.bossRef === boss);
  if (totemsAlive.length === 0) {
    boss.shieldActive = false;
    boss.invulnerable = false;
    boss.phase3Forced = true; 
    bossIntroData = {
      title: "ESCUDO QUEBRADO!",
      name: "O IMORTAL ESTÁ VULNERÁVEL",
      subtitle: "Acabe com ele!",
      color: "#00ff00"
    };
    bossIntroTimer = 1.5;
    triggerShake(0.8, 20);
    SoundManager.play('waveClear');
  }

  // Boss se move lentamente para não ficar totalmente parado
  const dx = player.x - boss.x;
  const dy = player.y - boss.y;
  const dist = Math.hypot(dx, dy);
  if (dist > 300) {
    boss.x += (dx / dist) * boss.speed * 0.4 * dt;
    boss.y += (dy / dist) * boss.speed * 0.4 * dt;
  }
}

  // === FASE 3 (<30%): FÚRIA DO REI IMORTAL ===
  else if (phase === 3) {
    boss.invulnerable = false;
    const interval = difficulty === "hard" ? 1.5 : 2.0;
    if (boss.bTimer >= interval) {
      boss.bTimer = 0;

      // Chuva de meteoros massiva (15 meteoros)
      for (let i = 0; i < 15; i++) {
        const angle = Math.random() * Math.PI * 2;
        const dist = 150 + Math.random() * 500;
        const tx = boss.x + Math.cos(angle) * dist;
        const ty = boss.y + Math.sin(angle) * dist;
        createAreaIndicator(tx, ty, 50, 1.2, "#ffaa00");
        setTimeout(() => {
          effects.push({
            type: "meteor",
            x: tx, y: ty,
            radius: 55,
            damage: CFG.ENEMY_DAMAGE * 2.0 * dmgMult,
            life: 0.6, maxLife: 0.6,
            color: "#eab308"
          });
          // Cada meteoro solta 6 projéteis em estrela
          for (let j = 0; j < 6; j++) {
            const a = (j / 6) * Math.PI * 2;
            enemyBullets.push({
              x: tx, y: ty,
              vx: Math.cos(a) * 220,
              vy: Math.sin(a) * 220,
              r: 8, life: 2.0,
              damage: CFG.ENEMY_DAMAGE * 0.7 * dmgMult,
              color: "#ff6633"
            });
          }
          spawnParticles(tx, ty, "#eab308", 30);
        }, 700);
      }

      // Rajada tripla de raios circulares (3 anéis com defasagem)
      for (let ring = 0; ring < 3; ring++) {
        const ringAngle = boss.phaseTimer * 3.0 + ring * Math.PI * 2 / 3;
        for (let i = 0; i < 24; i++) {
          const a = (i / 24) * Math.PI * 2 + ringAngle;
          enemyBullets.push({
            x: boss.x, y: boss.y,
            vx: Math.cos(a) * 300,
            vy: Math.sin(a) * 300,
            r: 11, life: 3.0,
            damage: CFG.ENEMY_DAMAGE * 1.5 * dmgMult,
            color: "#ffcc00"
          });
        }
      }

      // Invoca 5 Yakshas e 2 Asuras
      for (let i = 0; i < 5; i++) {
        const a = Math.random() * Math.PI * 2;
        const r = 180;
        spawnMinion(boss.x + Math.cos(a)*r, boss.y + Math.sin(a)*r, "Yaksha");
      }
      for (let i = 0; i < 2; i++) {
        const a = Math.random() * Math.PI * 2;
        const r = 180;
        spawnMinion(boss.x + Math.cos(a)*r, boss.y + Math.sin(a)*r, "Asura");
      }

      triggerShake(0.6, 15);
      SoundManager.play('special');
    }

    // Movimento rápido e errático com pequenos teleportes
    const dx = player.x - boss.x;
    const dy = player.y - boss.y;
    const dist = Math.hypot(dx, dy);
    if (dist > 150) {
      boss.x += (dx / dist) * boss.speed * 1.5 * dt;
      boss.y += (dy / dist) * boss.speed * 1.5 * dt;
    } else {
      boss.x -= (dx / dist) * boss.speed * 1.0 * dt;
      boss.y -= (dy / dist) * boss.speed * 1.0 * dt;
    }
  }

  // Limita posição
  boss.x = clamp(boss.x, CFG.WALL_THICKNESS + boss.r, CFG.ARENA_W - CFG.WALL_THICKNESS - boss.r);
  boss.y = clamp(boss.y, CFG.WALL_THICKNESS + boss.r, CFG.ARENA_H - CFG.WALL_THICKNESS - boss.r);

  break;
}
}
}

// invoca minion no meio da boss fight
function spawnMinion(x,y, typeName){
  const type = ENEMY_TYPES.find(t=>t.name===typeName) || ENEMY_TYPES[3];
  const diff = getDifficultyModifiers();
  const waveScale = 1 + (wave-1)*CFG.WAVE_HP_SCALE;
  const hp = CFG.ENEMY_HP*type.hpMult*waveScale*diff.hpMult*getPlayerScaleFactor();
  enemies.push({
    x, y, hp, maxHp:hp,
    speed: CFG.ENEMY_SPEED*type.spdMult*diff.spdMult,
    color:type.color, name:type.name, sprite:type.sprite, behavior:type.behavior,
    r: CFG.ENEMY_RADIUS*(type.sizeMult||1),
    hurtTimer:0, burnTimer:0, facing:1, animFrame:0,
    shootTimer: type.behavior==="ranged" ? 1.5+Math.random() : 0
  });
  spawnParticles(x,y,type.color,15);
}

