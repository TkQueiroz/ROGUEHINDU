function drawCrosshair(){
  const cx=aimX, cy=aimY;
  ctx.save(); ctx.shadowBlur=0;
  ctx.beginPath(); ctx.arc(cx,cy,8,0,Math.PI*2); ctx.strokeStyle="#FFF"; ctx.lineWidth=2; ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx-15,cy); ctx.lineTo(cx-5,cy); ctx.moveTo(cx+5,cy); ctx.lineTo(cx+15,cy);
  ctx.moveTo(cx,cy-15); ctx.lineTo(cx,cy-5); ctx.moveTo(cx,cy+5); ctx.lineTo(cx,cy+15); ctx.stroke();
  ctx.beginPath(); ctx.arc(cx,cy,4,0,Math.PI*2); ctx.fillStyle="#FF0000AA"; ctx.fill();
  ctx.restore();
}

function wrapText(text,x,y,maxW,lineH){
  const words = text.split(" "); let line = "";
  for(const w of words){
    const test = line+w+" ";
    if(ctx.measureText(test).width>maxW && line!==""){ ctx.fillText(line,x,y); line=w+" "; y+=lineH; }
    else line = test;
  }
  ctx.fillText(line,x,y);
}

/* ═══════════════════════════════════════════════════════════════════════════
   LOOP PRINCIPAL
   ═══════════════════════════════════════════════════════════════════════════ */
let lastTime = 0;
function loop(ts){
  const dt = Math.min((ts-lastTime)/1000, 0.05);
  lastTime = ts;
  if(state===STATES.PLAYING) updateNormal(dt);
  draw();
  requestAnimationFrame(loop);
}

function draw(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  if(state===STATES.MENU) drawMenu();
  else if(state===STATES.WEAPON_SELECT) drawWeaponSelect();
  else if(state===STATES.RANKING) drawRankingScreen();
  else if(state===STATES.CONTROLS) drawControlsScreen();
  else if(state===STATES.GAMEOVER) drawGameOver();
  else if(state===STATES.UPGRADE || state===STATES.PLAYING){
    const cam = getCamera();
    let sx=0, sy=0;
    if(screenShake.duration>0){
      sx = (Math.random()-0.5)*screenShake.intensity*2;
      sy = (Math.random()-0.5)*screenShake.intensity*2;
    }
ctx.save(); ctx.translate(canvas.width/2-cam.x+sx, canvas.height/2-cam.y+sy);
    drawArena(); drawParticles(); drawEffects();
    drawXpOrbs();
    drawEnemies(); drawBullets(); drawEnemyBullets();
    drawPlayer();
    drawDamageNumbers();
    ctx.restore();
    drawLowHpVignette();
    drawHUD();
    drawComboCounter();
    drawBossHealthBar();
    if(state===STATES.PLAYING){
      drawCrosshair();
      drawBossIntro();
    }
    if(state===STATES.UPGRADE) drawUpgradeScreen();;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   GAMEPAD + INPUT (igual ao anterior)
   ═══════════════════════════════════════════════════════════════════════════ */
function to_en(s){
  return s=="médio" ? "easy": s=="difícil" ? "normal" : "hard";
}

function updateGamepad(){
  const gps = navigator.getGamepads();
  for(let i=0;i<gps.length;i++){
    const gp = gps[i];
    if(gp && gp.connected){
      gamepadConnected=true; gamepadIndex=i;
      const id = gp.id.toLowerCase();
      if(id.includes('xbox')) gamepadType="Xbox";
      else if(id.includes('playstation')||id.includes('ps')) gamepadType="PlayStation";
      else gamepadType="Genérico";
      const badge = document.getElementById("ctrlBadge");
      if(badge) badge.innerHTML = `🎮 ${gamepadType} conectado`;
      return;
    }
  }
  gamepadConnected=false; gamepadIndex=null;
  const badge = document.getElementById("ctrlBadge");
  if(badge) badge.innerHTML = "🎮 Nenhum controle";
}
setInterval(updateGamepad,500);

function pollGamepadActions(){
  if(!gamepadConnected) return;
  const gp = navigator.getGamepads()[gamepadIndex];
  if(!gp) return;
  const aP=gp.buttons[0]?.pressed, bP=gp.buttons[1]?.pressed, xP=gp.buttons[2]?.pressed, yP=gp.buttons[3]?.pressed;
  const sP=gp.buttons[9]?.pressed;
  const dU=gp.buttons[12]?.pressed, dD=gp.buttons[13]?.pressed, dL=gp.buttons[14]?.pressed, dR=gp.buttons[15]?.pressed;
  const sY = gp.axes[1], dz=0.3;
  let up = dU || (sY<-dz), down = dD || (sY>dz);

  if(state===STATES.MENU){
    if(up){ menuIndex=(menuIndex-1+menuItems.length)%menuItems.length; delayAction(); }
    if(down){ menuIndex=(menuIndex+1)%menuItems.length; delayAction(); }
    if(dL||(gp.axes[0]<-dz)){ difficultyIndex=(difficultyIndex-1+difficulties.length)%difficulties.length; difficulty=to_en(difficulties[difficultyIndex].toLowerCase()); delayAction(); }
    if(dR||(gp.axes[0]>dz)){ difficultyIndex=(difficultyIndex+1)%difficulties.length; difficulty=to_en(difficulties[difficultyIndex].toLowerCase()); delayAction(); }
    if(aP||sP){
      if(menuItems[menuIndex]==="JOGAR") state=STATES.WEAPON_SELECT;
      else if(menuItems[menuIndex]==="RANKING"){ state=STATES.RANKING; loadRanking(); }
      else if(menuItems[menuIndex]==="CONTROLES") state=STATES.CONTROLS;
    }
  } else if(state===STATES.WEAPON_SELECT){
    if(bP){ state=STATES.MENU; SoundManager.startMenuMusic(); }
    if(dL||(gp.axes[0]<-dz)){
      let idx = WEAPONS.findIndex(c=>c===selectedWeapon); if(idx===-1) idx=0;
      selectedWeapon = WEAPONS[(idx-1+WEAPONS.length)%WEAPONS.length];
      delayAction();
    }
    if(dR||(gp.axes[0]>dz)){
      let idx = WEAPONS.findIndex(c=>c===selectedWeapon); if(idx===-1) idx=0;
      selectedWeapon = WEAPONS[(idx+1)%WEAPONS.length];
      delayAction();
    }
    if(aP && selectedWeapon) initGame();
  } else if(state===STATES.RANKING||state===STATES.CONTROLS){
    if(bP||aP||sP) state=STATES.MENU;
  } else if(state===STATES.GAMEOVER){
    if(aP||sP){ state=STATES.WEAPON_SELECT; selectedWeapon=null; SoundManager.startMenuMusic(); }
  } else if(state===STATES.UPGRADE){
    if(dL||(gp.axes[0]<-dz)){ upgradeSelectedIndex=(upgradeSelectedIndex-1+upgradeChoices.length)%upgradeChoices.length; delayAction(); }
    if(dR||(gp.axes[0]>dz)){ upgradeSelectedIndex=(upgradeSelectedIndex+1)%upgradeChoices.length; delayAction(); }
    if(xP) applyUpgrade(0);
    else if(yP) applyUpgrade(1);
    else if(aP) applyUpgrade(2);
  }
}
let actionDelay = false;
function delayAction(){ if(actionDelay) return; actionDelay=true; setTimeout(()=>{actionDelay=false;},200); }
setInterval(pollGamepadActions,100);

let last=null; 
window.addEventListener("keydown", ev => {
  const k = ev.key.toLowerCase(); 
  keys[k] = true;
  if(state===STATES.PLAYING){
    if(k==="e") useSpecial();
    if(k==="q" || k==" ") useDash();
    if(k==="r") useMelee();  
  }
  if (last==="1" && k==="ç") {hackMode=hackMode ? false : true; console.log("hackmode:" , hackMode); }
  if(hackMode){
    if(k==="u") wave++; 
    if(k==="h") player.hp+=10; 
    if(k=="m") player.damage++;
    if(k==="/" && last=="[") resetRanking();
    if(k==="p") player.damage+=100; 
  }
  if(state===STATES.MENU){
    if(k==="arrowup"){ menuIndex=(menuIndex-1+menuItems.length)%menuItems.length; ev.preventDefault(); }
    if(k==="arrowdown"){ menuIndex=(menuIndex+1)%menuItems.length; ev.preventDefault(); }
    if(k==="arrowleft"){ difficultyIndex=(difficultyIndex-1+difficulties.length)%difficulties.length; difficulty=to_en(difficulties[difficultyIndex].toLowerCase()); ev.preventDefault(); }
    if(k==="arrowright"){ difficultyIndex=(difficultyIndex+1)%difficulties.length; difficulty=to_en(difficulties[difficultyIndex].toLowerCase()); ev.preventDefault(); }
    if(k==="enter"){
      if(menuItems[menuIndex]==="JOGAR") state=STATES.WEAPON_SELECT;
      else if(menuItems[menuIndex]==="RANKING"){ state=STATES.RANKING; loadRanking(); }
      else if(menuItems[menuIndex]==="CONTROLES") state=STATES.CONTROLS;
    }
  }
  if(state===STATES.WEAPON_SELECT){
    if(k==="arrowleft"){
      let idx = WEAPONS.findIndex(c=>c===selectedWeapon); if(idx===-1) idx=0;
      selectedWeapon = WEAPONS[(idx-1+WEAPONS.length)%WEAPONS.length]; ev.preventDefault();
    }
    if(k==="arrowright"){
      let idx = WEAPONS.findIndex(c=>c===selectedWeapon); if(idx===-1) idx=-1;
      selectedWeapon = WEAPONS[(idx+1)%WEAPONS.length]; ev.preventDefault();
    }
    if(k==="enter" && selectedWeapon) initGame();
  }
  if(state!==STATES.UPGRADE && k==="escape"){ state=STATES.MENU; SoundManager.startMenuMusic(); }
  if(state===STATES.GAMEOVER && (k==="enter"||k===" ")){ 
    resetInputs(); 
    state=STATES.WEAPON_SELECT;
     selectedWeapon=null; 
     SoundManager.startMenuMusic(); 
    }
  if(state===STATES.UPGRADE){
    if(k==="1") applyUpgrade(0);
    if(k==="2") applyUpgrade(1);
    if(k==="3") applyUpgrade(2);
  }
    last=k;
});
window.addEventListener("keyup", ev => { keys[ev.key.toLowerCase()]=false; });
window.addEventListener("blur", () => { resetInputs(); });
document.addEventListener("visibilitychange", () => {
  if (document.hidden) resetInputs();
});


canvas.addEventListener("mousemove", ev => {
  const r = canvas.getBoundingClientRect();
  mouse.x = (ev.clientX-r.left)*(canvas.width/r.width);
  mouse.y = (ev.clientY-r.top)*(canvas.height/r.height);
  aimX = mouse.x; aimY = mouse.y;
});
canvas.addEventListener("mousedown", ev => {
  if(state===STATES.PLAYING){ mouse.down=true; return; }
  if(state===STATES.MENU){
    const r = canvas.getBoundingClientRect();
    const mx = (ev.clientX-r.left)*(canvas.width/r.width);
    const my = (ev.clientY-r.top)*(canvas.height/r.height);
    const menuYStart = canvas.height/2-5;
    for(let i=0;i<menuItems.length;i++){
      const y = menuYStart+i*50;
      if(Math.abs(mx-canvas.width/2)<120 && Math.abs(my-y)<25){
        if(menuItems[i]==="JOGAR"){ state=STATES.WEAPON_SELECT; SoundManager.startMenuMusic(); return; }
        else if(menuItems[i]==="RANKING"){ state=STATES.RANKING; loadRanking(); return; }
        else if(menuItems[i]==="CONTROLES"){ state=STATES.CONTROLS; return; }
        break;
      }
    }
    const diffY = menuYStart+4*50+60, diffW=120, diffH=40, diffGap=20;
    const totalDiffWidth = 3*diffW+2*diffGap;
    const diffStartX = canvas.width/2-totalDiffWidth/2;
    for(let i=0;i<difficulties.length;i++){
      const x = diffStartX+i*(diffW+diffGap), y=diffY;
      if(mx>=x && mx<=x+diffW && my>=y && my<=y+diffH){
        difficultyIndex=i; difficulty=to_en(difficulties[i].toLowerCase()); break;
      }
    }
  }
  if(state===STATES.WEAPON_SELECT){
    const r = canvas.getBoundingClientRect();
    const mx = (ev.clientX-r.left)*(canvas.width/r.width);
    const my = (ev.clientY-r.top)*(canvas.height/r.height);
    const cardW=260, cardH=200, gap=20;
    const totalW = cardW*WEAPONS.length + gap*(WEAPONS.length-1);
    const startX = (canvas.width-totalW)/2;
    const y = 110;
    for(let i=0;i<WEAPONS.length;i++){
      const x = startX + i*(cardW+gap);
      if(mx>=x && mx<=x+cardW && my>=y && my<=y+cardH){
        selectedWeapon = WEAPONS[i];
        initGame();
        break;
      }
    }
  }
  if(state===STATES.RANKING||state===STATES.CONTROLS){ state=STATES.MENU; SoundManager.startMenuMusic(); }
  if(state===STATES.GAMEOVER){ state=STATES.WEAPON_SELECT; selectedWeapon=null; SoundManager.startMenuMusic(); }
  if(state===STATES.UPGRADE){
    const r = canvas.getBoundingClientRect();
    const mx = (ev.clientX-r.left)*(canvas.width/r.width);
    const my = (ev.clientY-r.top)*(canvas.height/r.height);
    const cw=180, ch=100, gap=24;
    const totalW = 3*cw+2*gap;
    const startX = canvas.width/2 - totalW/2;
    const cy = canvas.height/2 - 40;
    upgradeChoices.forEach((_,i)=>{
      const x = startX + i*(cw+gap);
      if(mx>=x && mx<=x+cw && my>=cy && my<=cy+ch) applyUpgrade(i);
    });
  }
});
canvas.addEventListener("mouseup", ()=>{ mouse.down=false; });

if(!CanvasRenderingContext2D.prototype.roundRect){
  CanvasRenderingContext2D.prototype.roundRect = function(x,y,w,h,r){
    if(w<2*r) r=w/2; if(h<2*r) r=h/2;
    this.moveTo(x+r,y); this.lineTo(x+w-r,y); this.quadraticCurveTo(x+w,y,x+w,y+r);
    this.lineTo(x+w,y+h-r); this.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    this.lineTo(x+r,y+h); this.quadraticCurveTo(x,y+h,x,y+h-r);
    this.lineTo(x,y+r); this.quadraticCurveTo(x,y,x+r,y);
    return this;
  };
}

