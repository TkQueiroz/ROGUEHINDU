  if(player.burnChance && Math.random()<player.burnChance) enemy.burnTimer = CFG.BURN_DURATION;
  player.hp = Math.min(player.maxHp, player.hp + dmg*player.vamp);
  if(player.chain){
    let c=0;
    for(let k=0;k<enemies.length && c<3;k++){
      if(enemies[k]===enemy) continue;
      if(dist2(enemy,enemies[k])<150**2){
