let imgsLoaded = 0, imgsTotal = 0, imgsReady = false;

function preloadImages(callback) {
  const entries = Object.entries(IMG_PATHS);
  imgsTotal = entries.length;
  if (imgsTotal === 0) { imgsReady = true; callback && callback(); return; }
  for (const [key, src] of entries) {
    const im = new Image();
    im.onload  = () => { IMG[key] = im; imgsLoaded++; if (imgsLoaded >= imgsTotal) { imgsReady = true; callback && callback(); } };
    im.onerror = () => { IMG[key] = null;  imgsLoaded++; console.warn('[IMG] não encontrada:', src); if (imgsLoaded >= imgsTotal) { imgsReady = true; callback && callback(); } };
    im.src = src;
  }
}


// Decorações fixas espalhadas pela arena — geradas UMA VEZ no início do jogo
let arenaDecos = [];
function generateArenaDecos() {
  arenaDecos = [];
  const W = CFG.ARENA_W, H = CFG.ARENA_H, T = CFG.WALL_THICKNESS;
  const types = ['deco_ganesha','deco_hanuman','deco_naga','deco_pot','deco_torch','deco_candle'];
  const counts = { deco_ganesha:4, deco_hanuman:3, deco_naga:4, deco_pot:12, deco_torch:8, deco_candle:8 };
  for (const [type, count] of Object.entries(counts)) {
    for (let i = 0; i < count; i++) {
      // evita centro (onde o player spawna) e borda das paredes
      let x, y, attempts = 0;
      do {
        x = T + 60 + Math.random() * (W - T*2 - 120);
        y = T + 60 + Math.random() * (H - T*2 - 120);
        attempts++;
      } while (Math.hypot(x - W/2, y - H/2) < 300 && attempts < 20);
      arenaDecos.push({ type, x, y, scale: type.startsWith('deco_pot') || type.startsWith('deco_candle') ? 0.55 : 0.75 });
    }
  }
}


/* ═══════════════════════════════════════════════════════════════════════════
   SOUND MANAGER
   ═══════════════════════════════════════════════════════════════════════════ */
const SoundManager = (function() {
  let sounds={}, bgmMenu=null, bgmGame=null, currentBgm=null, muted=false, initialized=false;
  function loadSound(key,url){ return new Howl({src:[url],volume:1.5,onloaderror:(id,err)=>console.warn(`[Sound] ${key}`,err)}); }
  function init(){
    if(initialized) return;
    const f = { shoot:'sounds/shoot.mp3', hitEnemy:'sounds/hit_enemy.mp3', playerHurt:'sounds/player_hurt.mp3',
      levelUp:'sounds/level_up.mp3', special:'sounds/special.mp3', dash:'sounds/dash.mp3',
       powerup:'sounds/powerup_select.mp3',
      waveClear:'sounds/wave_clear.mp3', gameOver:'sounds/game_over.mp3' };
    for(const [k,u] of Object.entries(f)) sounds[k]=loadSound(k,u);
    bgmMenu = new Howl({src:['sounds/bgm_menu.mp3'],loop:true,volume:0.8,onloaderror:()=>{}});
    bgmGame = new Howl({src:['sounds/bgm_game.mp3'],loop:true,volume:0.3,onloaderror:()=>{}});
    initialized=true;
  }
  function startMenuMusic(){ if(!initialized) init();
    if(currentBgm===bgmGame && bgmGame.playing()) bgmGame.stop();
    if(currentBgm===bgmMenu && bgmMenu.playing()) return;
    if(bgmMenu && !bgmMenu.playing()){ bgmMenu.play(); currentBgm=bgmMenu; } }
  function startGameMusic(){ if(!initialized) init();
    if(currentBgm===bgmMenu && bgmMenu.playing()) bgmMenu.stop();
    if(currentBgm===bgmGame && bgmGame.playing()) return;
    if(bgmGame && !bgmGame.playing()){ bgmGame.play(); currentBgm=bgmGame; } }
  function stopAllMusic(){ if(bgmMenu&&bgmMenu.playing())bgmMenu.stop(); if(bgmGame&&bgmGame.playing())bgmGame.stop(); currentBgm=null; }
  function play(n){ if(!initialized) init(); if(muted) return; const s=sounds[n]; if(s) s.play(); }
  function toggleMute(){ muted=!muted; if(bgmMenu)bgmMenu.mute(muted); if(bgmGame)bgmGame.mute(muted);
    Object.values(sounds).forEach(s=>s.mute(muted)); return muted; }
  function startBackgroundMusic(){ startMenuMusic(); }
  return { init, startBackgroundMusic, startMenuMusic, startGameMusic, stopAllMusic, play, toggleMute };
})();

