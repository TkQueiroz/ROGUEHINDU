function updateNormal(dt){
  tick++;
  shootTimer = Math.max(0, shootTimer-dt);
  specialTimer = Math.max(0, specialTimer-dt);
  dashTimer = Math.max(0, dashTimer-dt);
  meleeCdTimer = Math.max(0, meleeCdTimer-dt);
  player.hurtTimer = Math.max(0, player.hurtTimer-dt);
  if(screenShake.duration>0) screenShake.duration -= dt;
  if(bossIntroTimer>0) bossIntroTimer -= dt;
  player.animFrame = (player.animFrame||0)+dt*6;

  if(player.invincibleTimer>0){ player.invincibleTimer-=dt; player.invincible = player.invincibleTimer>0; }
  else player.invincible = false;
  if(player.regen){ regenAccum+=dt; if(regenAccum>=1){ regenAccum=0; player.hp=Math.min(player.maxHp,player.hp+player.regen); } }
  if(player.canUseShield && !player.shield){
    player.shieldTimer+=dt; 
    if(player.shieldTimer>=player.shieldCooldown){ player.shield=true; player.shieldTimer=0; }
    }
  // movimento
  let dx=0, dy=0;
  if(keys["w"]||keys["arrowup"]) dy-=1;
  if(keys["s"]||keys["arrowdown"]) dy+=1;
  if(keys["a"]||keys["arrowleft"]) dx-=1;
  if(keys["d"]||keys["arrowright"]) dx+=1;
  if(gamepadConnected){
    const gp = navigator.getGamepads()[gamepadIndex];
    if(gp){
      const sX=gp.axes[0], sY=gp.axes[1];
      if(Math.abs(sX)>0.2) dx += sX;
      if(Math.abs(sY)>0.2) dy += sY;

    if(gp.buttons[6] && gp.buttons[6].pressed) 
      useDash();

    if((gp.buttons[4] && gp.buttons[4].pressed) || (gp.buttons[3] && gp.buttons[3].pressed)) 
      useSpecial();
    }
    
  }
  if(dx!==0||dy!==0){
    const len = Math.hypot(dx,dy);
    player.vx = dx/len*player.speed; player.vy = dy/len*player.speed;
    player.x += player.vx*dt; player.y += player.vy*dt;
    player.x = clamp(player.x, CFG.WALL_THICKNESS+player.r, CFG.ARENA_W-CFG.WALL_THICKNESS-player.r);
    player.y = clamp(player.y, CFG.WALL_THICKNESS+player.r, CFG.ARENA_H-CFG.WALL_THICKNESS-player.r);
    if(Math.abs(dx)>0.1) player.facing = dx>0 ? 1 : -1;
  } else { player.vx=0; player.vy=0; }

  if(gamepadConnected){
    const gp = navigator.getGamepads()[gamepadIndex];
    if(gp){
      const rX=gp.axes[2]||0, rY=gp.axes[3]||0;
      if(Math.abs(rX)>0.15||Math.abs(rY)>0.15){
        aimX += rX*aimSpeed*dt*2; aimY += rY*aimSpeed*dt*2;
        aimX = clamp(aimX,0,canvas.width); aimY = clamp(aimY,0,canvas.height);
      }
      for(let i=0; i<gp.buttons.length; i++){
      if(gp.buttons[i].pressed){
        console.log(`Botão ${i} pressionado`); 
    }
      }
    }
  }

  // mira atualiza facing do player quando atira
  const aimAng = getAimAngle();
  if(mouse.down) player.facing = Math.cos(aimAng)>0 ? 1 : -1;

  // atacar
  let shootNow = mouse.down;
  if(gamepadConnected){
    const gp = navigator.getGamepads()[gamepadIndex];
    if(gp && ( (gp.buttons[0] && gp.buttons[0].pressed)||(gp.buttons[7] && gp.buttons[7].pressed) )) shootNow = true;
  }
  if(shootNow && shootTimer<=0){
    shootTimer = player.shootCd;
    executeAttack();
  }

  // projéteis do jogador vs inimigos
  for(let i=bullets.length-1;i>=0;i--){
    const b = bullets[i];
    b.x += b.vx*dt; b.y += b.vy*dt; b.life -= dt;
    if(b.life<=0 || outOfArena(b)){ bullets.splice(i,1); continue; }
    let remove = false;
    for(let j=enemies.length-1;j>=0;j--){
      const e = enemies[j];
      if(b.hitSet && b.hitSet.has(e)) continue;
      if(dist2(b,e) < (b.r+e.r)**2){
        const dmg = player.damage;
          if (e.isBoss && e.invulnerable) continue; 
        e.hp -= dmg;
        applyHitEffects(e,j,dmg);
        SoundManager.play('hitEnemy');
        if(b.hitSet) b.hitSet.add(e);
        b.hitCount = (b.hitCount||0)+1;
        if(e.hp<=0) toKill.push(j);
        if(b.hitCount > b.pierce){ bullets.splice(i,1); remove=true; break; }
      }
    }
    if(remove) continue;
  }

  // projéteis inimigos vs jogador
  for(let i=enemyBullets.length-1;i>=0;i--){
    const b = enemyBullets[i];
    b.x += b.vx*dt; b.y += b.vy*dt; b.life -= dt;
    if(b.life<=0 || outOfArena(b)){ enemyBullets.splice(i,1); continue; }
    if(!player.invincible && player.hurtTimer<=0 && dist2(b,player) < (b.r+player.r)**2){
      if(player.shield){ player.shield=false; enemyBullets.splice(i,1); spawnParticles(player.x,player.y,"#3F51B5",20); continue; }
      player.hp -= b.damage;
      player.hurtTimer = 0.7;
      SoundManager.play('playerHurt');
      spawnParticles(player.x,player.y,"#FF1744",12);
      enemyBullets.splice(i,1);
      if(player.hp<=0){ gameOver(); return; }
      continue;
    }
  }

  // inimigos
  
  const diffMod = getDifficultyModifiers();
  const isHard = diffMod.isHard;
  for(let i=0;i<enemies.length;i++){
    const e = enemies[i];
    e.hurtTimer = Math.max(0, e.hurtTimer-dt);
    e.animFrame = (e.animFrame||0)+dt*4;

    // BOSS: comportamento próprio
    if(e.isBoss){
      updateBossBehavior(e, dt);
      // movimento: boss se aproxima lentamente do jogador quando não está em charge
      if(!(e.behavior==="charge" && e.chargeState==="charging")){
        let mdx=player.x-e.x, mdy=player.y-e.y;
        const d = Math.hypot(mdx,mdy) || 1;
        e.x += mdx/d*e.speed*dt; e.y += mdy/d*e.speed*dt;
        if(Math.abs(mdx)>1) e.facing = mdx>0?1:-1;
      } else {
        // facing em direção da charge
        e.facing = Math.cos(e.chargeAngle)>0?1:-1;
      }
    } else {
      // inimigos comuns
      let mdx=player.x-e.x, mdy=player.y-e.y;
      if(isHard){
        mdx = (player.x+player.vx*0.3)-e.x;
        mdy = (player.y+player.vy*0.3)-e.y;
      }
      const d = Math.hypot(mdx,mdy) || 1;
      // Gandharva mantém distância e atira
      if(e.behavior==="ranged"){
        const prefDist = 280;
        const approach = d > prefDist ? 1 : (d < prefDist-60 ? -0.6 : 0);
        e.x += mdx/d*e.speed*dt*approach;
        e.y += mdy/d*e.speed*dt*approach;
        e.shootTimer -= dt;
        if(e.shootTimer<=0 && d < 600){
          e.shootTimer = 1.8+Math.random()*0.6;
          const a = Math.atan2(mdy,mdx);
          enemyBullets.push({ x:e.x, y:e.y,
            vx:Math.cos(a)*240, vy:Math.sin(a)*240,
            r:7, life:3, damage:CFG.ENEMY_DAMAGE*0.7*diffMod.dmgMult*getPlayerScaleFactor(), color:"#06b6d4" });
        }
      } else {
        e.x += mdx/d*e.speed*dt;
        e.y += mdy/d*e.speed*dt;
      }
      if(Math.abs(mdx)>1) e.facing = mdx>0?1:-1;
    }

    // colisão com jogador
    const baseDmg = CFG.ENEMY_DAMAGE * diffMod.dmgMult * getPlayerScaleFactor();
    const enemyDmg = e.isBoss ? baseDmg * e.dmgMult : baseDmg;
    if(player.hurtTimer<=0 && !player.invincible && dist2(e,player) < (e.r+player.r)**2){
      if(player.shield){
        player.shield = false; player.hurtTimer = 0.7;
        spawnParticles(player.x,player.y,"#3F51B5",20);
      } else {
        player.hp -= enemyDmg;
        player.hurtTimer = 0.7;
        SoundManager.play('playerHurt');
        spawnParticles(player.x,player.y,"#FF1744",8);
        if(e.isBoss && e.behavior==="charge" && e.chargeState==="charging") triggerShake(0.3,10);
      }
      if(player.hp<=0){ gameOver(); return; }
    }
    if(e.burnTimer>0){ e.burnTimer-=dt; if(!(e.isBoss && e.invulnerable)) e.hp -= CFG.BURN_DAMAGE*dt; if(e.hp<=0) toKill.push(i); }
  }

  updateEffects(dt);
  //atualiza mortes pendentes
  if(toKill.length){
  const uniqueIndices = [...new Set(toKill)].sort((a, b) => b - a);
  for (let i of uniqueIndices) {
    killEnemy(i);
  }
  toKill = [];
}
  updateDamageNumbers(dt);
  updateXpOrbs(dt);
  updateCombo(dt);

  // partículas
  for(let i=particles.length-1;i>=0;i--){
    const p = particles[i];
    p.x += p.vx*dt; p.y += p.vy*dt; p.vy += 60*dt; p.life -= dt;
    if(p.life<=0) particles.splice(i,1);
  }

  if(waveCleared()){
    if(waveBreakTimer<=0){
      waveBreakTimer = CFG.WAVE_BREAK;
      SoundManager.play('waveClear');
    } else {
      waveBreakTimer -= dt;
      if(waveBreakTimer<=0) spawnWave();
    }
  }

  if(player.xp >= CFG.XP_PER_LEVEL*player.level){
    player.xp = 0; player.level++;
    player.damage += CFG.LEVEL_DMG_BONUS;
    player.maxHp += CFG.LEVEL_HP_BONUS;
    player.hp = Math.min(player.hp+CFG.LEVEL_HP_BONUS, player.maxHp);
    SoundManager.play('levelUp');
    levelUpUpgrade();
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
   RENDER — ARENA + TEMPLO
   ═══════════════════════════════════════════════════════════════════════════ */
function drawArena() {
  const W = CFG.ARENA_W, H = CFG.ARENA_H, T = CFG.WALL_THICKNESS;
  const tileSize = 96;

  /* ── FUNDO BASE ── cor ocre escura de templo */
  ctx.fillStyle = '#2a1506';
  ctx.fillRect(0, 0, W, H);

  /* ── CHÃO — grade de tiles alternados ── */
  const floorTiles = ['floor_stone','floor_lotus','floor_stone','floor_stone',
                      'floor_cracked','floor_stone','floor_om','floor_stone'];

  for (let tx = T; tx < W - T; tx += tileSize) {
    for (let ty = T; ty < H - T; ty += tileSize) {
      const col = Math.floor(tx / tileSize);
      const row = Math.floor(ty / tileSize);

      // padrão: lótus a cada 4 tiles em diagonal, om a cada 7
      let tileKey = 'floor_stone';
      if ((col + row) % 7 === 0)      tileKey = 'floor_om';
      else if ((col + row) % 4 === 0) tileKey = 'floor_lotus';
      else if ((col * row) % 11 === 3) tileKey = 'floor_cracked';

      const img = IMG[tileKey];
      if (img) {
        ctx.drawImage(img, tx, ty, tileSize, tileSize);
      } else {
        // fallback procedural — paleta ocre
        const alt = (col + row) % 2 === 0;
        ctx.fillStyle = alt ? '#3d2208' : '#2e1a06';
        ctx.fillRect(tx, ty, tileSize, tileSize);
        // detalhe central
        ctx.fillStyle = '#5a3412';
        ctx.fillRect(tx + tileSize/2 - 3, ty + tileSize/2 - 3, 6, 6);
      }
      // borda de tile sutil
      ctx.strokeStyle = 'rgba(0,0,0,0.18)';
      ctx.lineWidth = 1;
      ctx.strokeRect(tx, ty, tileSize, tileSize);
    }
  }

  /* ── MANDALA CENTRAL PROCEDURAL (substitui emoji) ── */
  ctx.save();
  ctx.translate(W / 2, H / 2);
  ctx.rotate(tick * 0.001);
  // pétalas de lótus
  for (let p = 0; p < 8; p++) {
    ctx.save();
    ctx.rotate((p / 8) * Math.PI * 2);
    ctx.fillStyle = `rgba(218,165,32,${0.06 + 0.02 * Math.sin(tick * 0.03 + p)})`;
    ctx.beginPath();
    ctx.ellipse(0, -180, 30, 80, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }
  // círculos concêntricos dourados
  for (let r = 80; r < 700; r += 110) {
    ctx.strokeStyle = `rgba(218,165,32,${0.10 - r * 0.00008})`;
    ctx.lineWidth = r < 250 ? 2 : 1;
    ctx.beginPath(); ctx.arc(0, 0, r, 0, Math.PI * 2); ctx.stroke();
  }
  // octágono central
  ctx.strokeStyle = 'rgba(218,165,32,0.18)';
  ctx.lineWidth = 2;
  ctx.beginPath();
  for (let i = 0; i < 8; i++) {
    const a = (i / 8) * Math.PI * 2;
    i === 0 ? ctx.moveTo(Math.cos(a)*120, Math.sin(a)*120)
            : ctx.lineTo(Math.cos(a)*120, Math.sin(a)*120);
  }
  ctx.closePath(); ctx.stroke();
  ctx.restore();

  /* ── DECORAÇÕES (estátuas, potes, tochas) ── */
  for (const d of arenaDecos) {
    const img = IMG[d.type];
    if (!img) {
      // fallback: círculo colorido simples
      ctx.fillStyle = d.type.includes('torch') || d.type.includes('fire') ? '#ff6a00' : '#8B4513';
      ctx.beginPath(); ctx.arc(d.x, d.y, 10, 0, Math.PI * 2); ctx.fill();
      continue;
    }
    const w = img.naturalWidth  * d.scale;
    const h = img.naturalHeight * d.scale;

    // sombra suave
    ctx.save();
    ctx.fillStyle = 'rgba(0,0,0,0.28)';
    ctx.beginPath(); ctx.ellipse(d.x, d.y + h * 0.46, w * 0.4, h * 0.1, 0, 0, Math.PI * 2); ctx.fill();
    ctx.restore();

    // tochas e fogo: animação de brilho pulsante
    if (d.type === 'deco_torch' || d.type === 'deco_fire' || d.type === 'deco_candle') {
      const glow = 8 + Math.sin(tick * 0.2 + d.x) * 4;
      ctx.save();
      ctx.shadowBlur  = glow;
      ctx.shadowColor = '#ff8c00';
      ctx.drawImage(img, d.x - w/2, d.y - h/2, w, h);
      ctx.restore();
    } else {
      ctx.drawImage(img, d.x - w/2, d.y - h/2, w, h);
    }
  }

  /* ── PAREDES — 4 lados ── */
  // cor sólida base
  ctx.fillStyle = '#8B4513';
  ctx.fillRect(0, 0,   W,   T);          // topo
  ctx.fillRect(0, H-T, W,   T);          // base
  ctx.fillRect(0, 0,   T,   H);          // esquerda
  ctx.fillRect(W-T, 0, T,   H);          // direita

  // textura de parede com imagens
  const wallImg     = IMG['wall_top'];
  const snakeImg    = IMG['wall_snake'];
  const ganeshaImg  = IMG['wall_ganesha'];
  const pillarImg   = IMG['wall_pillar'];

  if (wallImg) {
    // parede superior — repete a imagem horizontalmente
    const wh = wallImg.naturalHeight;
    const scaledWH = T;
    for (let x = 0; x < W; x += wallImg.naturalWidth * (scaledWH / wh)) {
      ctx.drawImage(wallImg, x, 0, wallImg.naturalWidth * (scaledWH / wh), scaledWH);
      // espelha na parede inferior
      ctx.save(); ctx.scale(1,-1);
      ctx.drawImage(wallImg, x, -H, wallImg.naturalWidth * (scaledWH / wh), scaledWH);
      ctx.restore();
    }
  }

  // painéis de cobra nas paredes superior e inferior, de 320 em 320px
  if (snakeImg) {
    const sw = 160, sh = T;
    for (let x = T + 40; x < W - T - sw; x += 320) {
      ctx.drawImage(snakeImg, x, 0,   sw, sh);
      ctx.drawImage(snakeImg, x, H-T, sw, sh);
    }
  }

  // Ganesha no centro de cada parede
  if (ganeshaImg) {
    const gw = 80, gh = T * 1.6;
    // topo
    ctx.drawImage(ganeshaImg, W/2 - gw/2, -gh*0.2, gw, gh);
    // base
    ctx.save(); ctx.translate(W/2, H - T + gh*0.2); ctx.scale(1,-1);
    ctx.drawImage(ganeshaImg, -gw/2, 0, gw, gh);
    ctx.restore();
  }

  // pilares nos cantos e a cada 400px nas paredes
  if (pillarImg) {
    const pw = 36, ph = T * 1.4;
    const pillarPositionsX = [T, T+200, W/2-18, W-T-200, W-T-pw];
    for (const px of pillarPositionsX) {
      ctx.drawImage(pillarImg, px, -ph * 0.2, pw, ph);               // parede topo
      ctx.save(); ctx.translate(px + pw/2, H - T + ph*0.2); ctx.scale(1,-1);
      ctx.drawImage(pillarImg, -pw/2, 0, pw, ph); ctx.restore();      // parede base
    }
  }

  /* ── DETALHES PROCEDURAIS SOBRE AS PAREDES (blocos de pedra) ── */
  ctx.fillStyle = 'rgba(0,0,0,0.18)';
  for (let x = 0; x < W; x += 80) {
    ctx.fillRect(x+2, 4,   76, 6);
    ctx.fillRect(x+2, T-10, 76, 6);
    ctx.fillRect(x+2, H-T+4, 76, 6);
    ctx.fillRect(x+2, H-10,  76, 6);
  }
  // bordão dourado interno
  ctx.strokeStyle = '#DAA520';
  ctx.lineWidth = 3;
  ctx.strokeRect(T, T, W - T*2, H - T*2);
  // segundo bordão
  ctx.strokeStyle = 'rgba(218,165,32,0.3)';
  ctx.lineWidth = 1;
  ctx.strokeRect(T + 6, T + 6, W - T*2 - 12, H - T*2 - 12);
}


function getPlayerSpriteAndFacing(){
  // Prioridade: hurt > dash > attack > walk
  if(player.hurtTimer > 0.35) return { key:"player_hurt", facing: player.facing };
  if(dashTimer > CFG.DASH_COOLDOWN - 0.35) return { key:"player_dash", facing: player.facing };

  // atacando — flash recente do tiro
  const attacking = shootTimer > player.shootCd - 0.12 && shootTimer > 0;
  if(attacking) return { key:"player_attack", facing: player.facing };

  // determina direção baseado em MOVIMENTO (prioritário) ou MIRA
  const moving = Math.abs(player.vx) > 1 || Math.abs(player.vy) > 1;
  let dx, dy;
  if(moving){ dx = player.vx; dy = player.vy; }
  else { const w = getAimWorld(); dx = w.x - player.x; dy = w.y - player.y; }

  const absX = Math.abs(dx), absY = Math.abs(dy);
  let dir, face = player.facing;
  if(absX > absY){
    dir = "side";
    face = dx > 0 ? 1 : -1;
  } else {
    dir = dy > 0 ? "down" : "up";
  }
  // memoriza facing para quando voltar a parar
  if(moving && dir==="side") player.facing = face;

  // frame 0/1 alternando quando em movimento
  const frame = moving ? (Math.floor(tick/8) % 2) : 0;
  return { key: `player_${dir}_${frame}`, facing: face };
}

function drawPlayer(){
  if(player.hurtTimer>0 && Math.floor(tick/4)%2===0) return;
  const moving = Math.abs(player.vx)>1 || Math.abs(player.vy)>1;
  const bob = moving ? Math.sin(tick*0.35)*1.5 : Math.sin(tick*0.08)*1;

  // aura de especial pronto
  if(specialTimer<=0){
    ctx.save(); ctx.translate(player.x, player.y);
    const pulse = 1 + Math.sin(tick*0.15)*0.1;
    ctx.strokeStyle = selectedWeapon ? selectedWeapon.color+"aa" : "#00FFFFaa";
    ctx.lineWidth = 2; ctx.setLineDash([4,4]);
    ctx.beginPath(); ctx.arc(0,0,(player.r+12)*pulse,0,Math.PI*2); ctx.stroke();
    ctx.setLineDash([]); ctx.restore();
  }
  // escudo
  if(player.shield){
    ctx.save(); ctx.translate(player.x, player.y);
    ctx.strokeStyle="#3F51B5"; ctx.lineWidth=3;
    ctx.beginPath(); ctx.arc(0,0,player.r+8,0,Math.PI*2); ctx.stroke();
    ctx.restore();
  }
  // sombra sob o player
  ctx.save();
  ctx.fillStyle="rgba(0,0,0,0.35)";
  ctx.beginPath(); ctx.ellipse(player.x, player.y+player.r-1, player.r*0.8, player.r*0.28, 0, 0, Math.PI*2); ctx.fill();
  ctx.restore();

  // rastro de dash
  if(dashTimer > CFG.DASH_COOLDOWN - 0.35){
    const trailAlpha = (dashTimer - (CFG.DASH_COOLDOWN - 0.35)) / 0.35;
    ctx.save();
    ctx.globalAlpha = trailAlpha * 0.4;
    for(let i=1;i<=3;i++){
      drawSprite("player_dash", player.x - player.vx*0.02*i, player.y - player.vy*0.02*i, 1.4, player.facing||1, 0);
    }
    ctx.restore();
  }

  const { key, facing } = getPlayerSpriteAndFacing();
  drawSprite(key, player.x, player.y, 1.4, facing, bob);
}

function drawEnemies(){
  for(const e of enemies){
    const bob = Math.sin(e.animFrame*1.5)*1.5;
    // sombra sob o inimigo
    ctx.save();
    ctx.fillStyle="rgba(0,0,0,0.3)";
    ctx.beginPath(); ctx.ellipse(e.x, e.y+e.r-2, e.r*0.9, e.r*0.3, 0, 0, Math.PI*2); ctx.fill();
    ctx.restore();
    // flash branco quando machucado
    const hurt = e.hurtTimer>0 && Math.floor(tick/3)%2===0;
    const spriteScale = e.isBoss ? (e.r/16)*1.1 : (e.r/16)*1.0;
    if(hurt){
      // desenha o sprite e sobrepõe branco translúcido
      drawSprite(e.sprite, e.x, e.y, spriteScale, e.facing||1, bob);
      ctx.save();
      ctx.globalAlpha = 0.5;
      ctx.globalCompositeOperation = "source-atop";
      // para flash, redesenhamos um retângulo branco limitado ao bounding box do sprite
      const spr = SpriteCache[e.sprite];
      if(spr){
        const w = spr.width*spriteScale, h = spr.height*spriteScale;
        ctx.fillStyle = "#ffffff";
        ctx.fillRect(e.x-w/2, e.y-h/2+bob, w, h);
      }
      ctx.restore();
    } else {
      drawSprite(e.sprite, e.x, e.y, spriteScale, e.facing||1, bob);
    }
    // barra de HP (só para não-boss)
    if(!e.isBoss && e.hp < e.maxHp){
      const bw = e.r*2+6, bh=5;
      ctx.fillStyle="#333"; ctx.fillRect(e.x-bw/2, e.y-e.r-16, bw, bh);
      ctx.fillStyle="#00E676"; ctx.fillRect(e.x-bw/2, e.y-e.r-16, bw*(e.hp/e.maxHp), bh);
    }
    // queimadura
    if(e.burnTimer>0){
      ctx.fillStyle="#FF6600";
      ctx.beginPath(); ctx.arc(e.x, e.y+e.r, 5, 0, Math.PI*2); ctx.fill();
    }
    // indicador de boss em charge
    if(e.isBoss && e.chargeState==="winding"){
      ctx.save();
      ctx.strokeStyle="#ff0000"; ctx.lineWidth=4;
      ctx.globalAlpha = 0.6 + Math.sin(tick*0.5)*0.4;
      ctx.beginPath();
      ctx.moveTo(e.x, e.y);
      ctx.lineTo(e.x+Math.cos(e.chargeAngle)*1200, e.y+Math.sin(e.chargeAngle)*1200);
      ctx.stroke();
      ctx.restore();
    }
    if (e.isBoss && e.invulnerable) {
  ctx.save();
  ctx.shadowBlur = 25;
  ctx.shadowColor = "#FFD700";
  ctx.strokeStyle = "#FFD700";
  ctx.lineWidth = 4;
  ctx.beginPath();
  ctx.arc(e.x, e.y, e.r + 10, 0, Math.PI * 2);
  ctx.stroke();
  ctx.restore();
}
  }
}

function drawBullets(){
  for(const b of bullets){
    ctx.save();
    ctx.translate(b.x, b.y);
    if(b.kind==="arrow"){
      ctx.rotate(b.angle||0);
      ctx.fillStyle = b.color||"#FFAA00";
      ctx.shadowBlur = 6; ctx.shadowColor = b.color||"#FFAA00";
      ctx.fillRect(-10,-1.5,20,3);
      ctx.beginPath(); ctx.moveTo(10,0); ctx.lineTo(6,-4); ctx.lineTo(6,4); ctx.closePath(); ctx.fill();
      ctx.fillStyle="#FFFFFF"; ctx.fillRect(-11,-3,3,6);
    } else if(b.kind==="spear"){
      ctx.rotate(b.angle||0);
      ctx.shadowBlur=10; ctx.shadowColor=b.color||"#7C4DFF";
      ctx.fillStyle=b.color||"#7C4DFF";
      ctx.fillRect(-20,-2,40,4);
      ctx.beginPath(); ctx.moveTo(24,0); ctx.lineTo(18,-5); ctx.lineTo(18,5); ctx.closePath(); ctx.fill();
    } else {
      ctx.fillStyle="#FFD700"; ctx.shadowBlur=8;
      ctx.beginPath(); ctx.arc(0,0,b.r,0,Math.PI*2); ctx.fill();
    }
    ctx.restore();
  }
}

function drawEnemyBullets(){
  for(const b of enemyBullets){
    ctx.save();
    ctx.translate(b.x,b.y);
    ctx.shadowBlur = b.fireball ? 18 : 10;
    ctx.shadowColor = b.color||"#ff3366";
    ctx.fillStyle = b.color||"#ff3366";
    ctx.beginPath(); ctx.arc(0,0,b.r,0,Math.PI*2); ctx.fill();
    if(b.fireball){
      // núcleo branco
      ctx.fillStyle="#ffecc0";
      ctx.beginPath(); ctx.arc(0,0,b.r*0.5,0,Math.PI*2); ctx.fill();
    } else {
      ctx.fillStyle="#ffffff";
      ctx.beginPath(); ctx.arc(0,0,b.r*0.4,0,Math.PI*2); ctx.fill();
    }
    ctx.restore();
  }
}

function drawParticles(){
  for(const p of particles){
    ctx.globalAlpha = p.life/p.maxLife;
    ctx.fillStyle = p.color;
    ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2); ctx.fill();
  }
  ctx.globalAlpha = 1;
}

function drawEffects(){
  for(const fx of effects){
    const t = Math.max(0, fx.life/fx.maxLife);
    if(fx.type==="arcSlash"){
      ctx.save(); ctx.translate(fx.x,fx.y); ctx.rotate(fx.angle);
      ctx.globalAlpha = t;
      const grad = ctx.createRadialGradient(0,0,10,0,0,fx.range);
      grad.addColorStop(0,"rgba(255,255,255,0.0)"); grad.addColorStop(0.7,fx.color+"80"); grad.addColorStop(1,fx.color+"00");
      ctx.fillStyle = grad;
      ctx.beginPath(); ctx.moveTo(0,0); ctx.arc(0,0,fx.range, -fx.arc/2, fx.arc/2); ctx.closePath(); ctx.fill();
      ctx.strokeStyle="#FFFFFF"; ctx.lineWidth=3*t;
      ctx.beginPath(); ctx.arc(0,0,fx.range*(0.6+0.4*(1-t)), -fx.arc/2, fx.arc/2); ctx.stroke();
      ctx.restore(); ctx.globalAlpha=1; continue;
    }
    if(fx.type==="ringSlash"){
      ctx.save(); ctx.globalAlpha = t;
      const curR = fx.range*(1.1-0.15*t);
      const grad = ctx.createRadialGradient(fx.x,fx.y,curR*0.5,fx.x,fx.y,curR);
      grad.addColorStop(0,"rgba(255,255,255,0.0)"); grad.addColorStop(0.7,fx.color+"55"); grad.addColorStop(1,fx.color+"00");
      ctx.fillStyle = grad;
      ctx.beginPath(); ctx.arc(fx.x,fx.y,curR,0,Math.PI*2); ctx.fill();
      ctx.strokeStyle="#FFFFFF"; ctx.lineWidth=3*t;
      ctx.beginPath(); ctx.arc(fx.x,fx.y,curR,0,Math.PI*2); ctx.stroke();
      ctx.restore(); ctx.globalAlpha=1; continue;
    }
    if(fx.type==="bladeStorm"){
      ctx.save(); ctx.translate(fx.x,fx.y);
      ctx.globalAlpha = 0.7*t+0.3;
      ctx.strokeStyle=fx.color; ctx.lineWidth=3;
      ctx.setLineDash([10,6]); ctx.lineDashOffset = -tick*0.8;
      ctx.beginPath(); ctx.arc(0,0,fx.radius,0,Math.PI*2); ctx.stroke();
      ctx.setLineDash([]);
      for(let i=0;i<6;i++){
        const ang = tick*0.15+i*Math.PI/3;
        const bx=Math.cos(ang)*fx.radius*0.85, by=Math.sin(ang)*fx.radius*0.85;
        ctx.save(); ctx.translate(bx,by); ctx.rotate(ang+Math.PI/2);
        ctx.fillStyle="#FFFFFF"; ctx.shadowBlur=12; ctx.shadowColor=fx.color;
        ctx.beginPath(); ctx.moveTo(0,-18); ctx.lineTo(6,0); ctx.lineTo(0,18); ctx.lineTo(-6,0); ctx.closePath(); ctx.fill();
        ctx.restore();
      }
      ctx.restore(); ctx.globalAlpha=1; continue;
    }
    if(fx.type==="shockwave" || fx.type==="bossShockwave"){
      if (fx.startDelay > 0) continue;
  ctx.save(); ctx.globalAlpha = t * 0.9;
  ctx.strokeStyle = fx.color; ctx.lineWidth = fx.thickness * t;
  ctx.shadowBlur = 20; ctx.shadowColor = fx.color;

  if (fx.gapArc > 0) {
    // Desenha o arco GRANDE (a parte perigosa) deixando a brecha vazia
    const start = fx.gapAngle + fx.gapArc / 2;
    const end = start + (Math.PI * 2 - fx.gapArc); // cobre 360° - gapArc
    ctx.beginPath();
    ctx.arc(fx.x, fx.y, fx.radius, start, end, false);
    ctx.stroke();
  } else {
    ctx.beginPath();
    ctx.arc(fx.x, fx.y, fx.radius, 0, Math.PI * 2);
    ctx.stroke();
  }

  // Borda branca (também respeita a brecha)
  ctx.shadowBlur = 0; ctx.strokeStyle = "#FFFFFF"; ctx.lineWidth = 4 * t;
  if (fx.gapArc > 0) {
    const start = fx.gapAngle + fx.gapArc / 2;
    const end = start + (Math.PI * 2 - fx.gapArc);
    ctx.beginPath();
    ctx.arc(fx.x, fx.y, fx.radius, start, end, false);
    ctx.stroke();
  } else {
    ctx.beginPath();
    ctx.arc(fx.x, fx.y, fx.radius, 0, Math.PI * 2);
    ctx.stroke();
  }
      ctx.restore(); ctx.globalAlpha=1; continue;
    }
    if(fx.type==="arrowRain"){
      ctx.save(); ctx.globalAlpha=0.25+0.15*Math.sin(tick*0.2);
      ctx.fillStyle="#FFAA00"; ctx.beginPath(); ctx.arc(fx.x,fx.y,fx.radius,0,Math.PI*2); ctx.fill();
      ctx.globalAlpha=0.8; ctx.strokeStyle="#FFAA00"; ctx.lineWidth=3;
      ctx.setLineDash([12,8]); ctx.lineDashOffset=-tick*0.5;
      ctx.beginPath(); ctx.arc(fx.x,fx.y,fx.radius,0,Math.PI*2); ctx.stroke();
      ctx.setLineDash([]); ctx.restore(); ctx.globalAlpha=1; continue;
    }
    if(fx.type==="fallingArrow"){
      const prog = 1 - (fx.life/fx.maxLife);
      const py = fx.startY + (fx.y-fx.startY)*prog;
      ctx.save(); ctx.translate(fx.x,py); ctx.rotate(Math.PI/2);
      ctx.fillStyle=fx.color; ctx.shadowBlur=8; ctx.shadowColor=fx.color;
      ctx.fillRect(-8,-1.5,16,3);
      ctx.beginPath(); ctx.moveTo(8,0); ctx.lineTo(4,-4); ctx.lineTo(4,4); ctx.closePath(); ctx.fill();
      ctx.restore();
      if(!fx.impacted){
        ctx.save(); ctx.globalAlpha=0.4; ctx.strokeStyle="#FF0000"; ctx.lineWidth=2;
        ctx.beginPath(); ctx.arc(fx.x,fx.y,10,0,Math.PI*2); ctx.stroke();
        ctx.restore();
      }
      continue;
    }
    if(fx.type==="divineSpear"){
      ctx.save(); ctx.translate(fx.x,fx.y); ctx.rotate(fx.angle);
      ctx.globalAlpha=t;
      ctx.fillStyle="#FFFFFF"; ctx.shadowBlur=30; ctx.shadowColor=fx.color;
      ctx.fillRect(0,-fx.width/2,fx.length,fx.width);
      ctx.fillStyle=fx.color; ctx.globalAlpha=t*0.6;
      ctx.fillRect(0,-fx.width*0.8,fx.length,fx.width*1.6);
      ctx.globalAlpha=t; ctx.strokeStyle="#FFFFFF"; ctx.lineWidth=2;
      for(let i=0;i<5;i++){
        const off = (i/5)*fx.length+Math.random()*80;
        ctx.beginPath(); ctx.moveTo(off,0); ctx.lineTo(off+20+Math.random()*30, (Math.random()-0.5)*120); ctx.stroke();
      }
      ctx.restore(); ctx.globalAlpha=1; continue;
    }
if (fx.type === "meteor") {
  ctx.save();
  ctx.globalAlpha = fx.life / fx.maxLife;
  ctx.fillStyle = fx.color;
  ctx.shadowBlur = 20;
  ctx.shadowColor = "#ffaa00";
  ctx.beginPath();
  ctx.arc(fx.x, fx.y, fx.radius, 0, Math.PI*2);
  ctx.fill();
  ctx.restore();
  continue;
}
  }
}

