// Renderiza pixel-art para offscreen canvas
function renderPixelSprite(rows, palette, pixelSize=3) {
  const h = rows.length, w = rows[0].length;
  const c = document.createElement('canvas');
  c.width = w*pixelSize; c.height = h*pixelSize;
  const cx = c.getContext('2d');
  cx.imageSmoothingEnabled = false;
  for(let y=0;y<h;y++){
    const row = rows[y];
    for(let x=0;x<w;x++){
      const ch = row[x];
      const col = palette[ch];
      if(col){ cx.fillStyle = col; cx.fillRect(x*pixelSize, y*pixelSize, pixelSize, pixelSize); }
    }
  }
  return c;
}

const SpriteCache = {};
function initSprites(){
  for(const [key,rows] of Object.entries(SPR)){
    // bosses maiores → pixelSize maior; normais pixelSize 3
    const ps = key.startsWith('boss_') ? 4 : 3;
    SpriteCache[key] = renderPixelSprite(rows, PAL, ps);
  }
}

function drawSprite(key, x, y, scale=1, facing=1, bob=0){
   const extKey = BOSS_IMG_MAP[key];
  if (extKey && IMG[extKey]) {
    const img = IMG[extKey];
    const w = img.naturalWidth  * scale * 0.9;
    const h = img.naturalHeight * scale * 0.9;
    ctx.save();
    ctx.translate(Math.round(x), Math.round(y + bob));
    if (facing < 0) ctx.scale(-1, 1);
    ctx.imageSmoothingEnabled = false;
    ctx.drawImage(img, -w/2, -h/2, w, h);
    ctx.restore();
    return;
  }
  const s = SpriteCache[key];
  if(!s) return;
  ctx.save();
  ctx.translate(Math.round(x), Math.round(y+bob));
  if(facing<0) ctx.scale(-1,1);
  ctx.imageSmoothingEnabled = false;
  const w = s.width*scale, h = s.height*scale;
  ctx.drawImage(s, -w/2, -h/2, w, h);
  ctx.restore();
}

