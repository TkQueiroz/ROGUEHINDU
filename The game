    vx: (Math.random()-0.5)*40, vy: -90-Math.random()*40,
    life: 0.85, maxLife: 0.85,
    color: color || "#ffee88",
    scale: value > 100 ? 1.7 : (value > 50 ? 1.3 : 1)
  });
}

function spawnXpOrb(x, y, value){
  xpOrbs.push({
    x, y, value,
    vx: (Math.random()-0.5)*220, vy: (Math.random()-0.5)*220 - 80,
    life: 18, pulse: Math.random()*Math.PI*2, attract: false
  });
}

function updateDamageNumbers(dt){
  for(let i=damageNumbers.length-1;i>=0;i--){
    const d = damageNumbers[i];
    d.x += d.vx*dt; d.y += d.vy*dt;
    d.vy += 180*dt; // gravidade suave
    d.life -= dt;
    if(d.life<=0) damageNumbers.splice(i,1);
  }
}

function updateXpOrbs(dt){
  for(let i=xpOrbs.length-1;i>=0;i--){
    const o = xpOrbs[i];
    o.life -= dt; o.pulse += dt*4;
    if(o.life<=0){ xpOrbs.splice(i,1); continue; }
    const dx = player.x - o.x, dy = player.y - o.y;
    const d = Math.hypot(dx,dy);
    // magnetismo — quando player entra em raio de atração, orb persegue
    if(d < 200 || o.attract){
      o.attract = true;
      if(d > 0.1){
        const pull = 900;
        o.vx += (dx/d) * pull * dt;
        o.vy += (dy/d) * pull * dt;
      }
    }
    // atrito
    o.vx *= 0.92; o.vy *= 0.92;
    o.x += o.vx*dt; o.y += o.vy*dt;
    // coleta
    if(d < player.r + 14){
      player.xp += o.value;
      xpOrbs.splice(i,1);
      spawnParticles(o.x, o.y, "#a855f7", 6);
    }
  }
}

function updateCombo(dt){
  if(comboTimer > 0){
    comboTimer -= dt;
    if(comboTimer <= 0) comboCount = 0;
  }
}

function addCombo(){
  comboCount++;
  comboTimer = COMBO_DURATION;
}

function drawDamageNumbers(){
  ctx.save();
  ctx.textAlign = "center";
  for(const d of damageNumbers){
    const t = d.life/d.maxLife;
    ctx.globalAlpha = Math.min(1, t*1.4);
    ctx.font = `bold ${Math.round(15*d.scale)}px Arial`;
    ctx.strokeStyle = "#000"; ctx.lineWidth = 3;
    ctx.strokeText(d.value, d.x, d.y);
    ctx.fillStyle = d.color;
    ctx.fillText(d.value, d.x, d.y);
  }
  ctx.restore();
  ctx.globalAlpha = 1;
  ctx.textAlign = "left";
}

function drawXpOrbs(){
  ctx.save();
  for(const o of xpOrbs){
    const sz = 5 + Math.sin(o.pulse)*1.5;
    // halo externo
    ctx.globalAlpha = 0.3;
    ctx.fillStyle = "#a855f7";
    ctx.beginPath(); ctx.arc(o.x, o.y, sz*2, 0, Math.PI*2); ctx.fill();
    // núcleo roxo com glow
    ctx.globalAlpha = 1;
    ctx.shadowBlur = 14; ctx.shadowColor = "#a855f7";
    ctx.fillStyle = "#c084fc";
    ctx.beginPath(); ctx.arc(o.x, o.y, sz, 0, Math.PI*2); ctx.fill();
    // brilho central branco
    ctx.shadowBlur = 0;
    ctx.fillStyle = "#f5e8ff";
    ctx.beginPath(); ctx.arc(o.x-1, o.y-1, sz*0.45, 0, Math.PI*2); ctx.fill();
  }
  ctx.restore();
  ctx.globalAlpha = 1;
}

function drawComboCounter(){
  if(comboCount < 3) return;
  const t = Math.max(0, comboTimer/COMBO_DURATION);
  ctx.save();
  ctx.globalAlpha = t;
  ctx.textAlign = "center";
  const cx = canvas.width - 130, cy = 150;
  const fontSize = 22 + Math.min(comboCount*1.2, 20);
  ctx.font = `bold ${fontSize}px Arial`;
  // cor escala conforme combo sobe
  const color = comboCount >= 15 ? "#FF3D71" : (comboCount >= 8 ? "#FFAA44" : "#FFD700");
  ctx.strokeStyle = "#000"; ctx.lineWidth = 4;
  ctx.strokeText(`${comboCount} COMBO!`, cx, cy);
  ctx.fillStyle = color;
  ctx.fillText(`${comboCount} COMBO!`, cx, cy);
  // barra de timer
  const bw = 140, bh = 5;
  ctx.fillStyle = "rgba(0,0,0,0.6)";
  ctx.fillRect(cx-bw/2, cy+10, bw, bh);
  ctx.fillStyle = color;
  ctx.fillRect(cx-bw/2, cy+10, bw*t, bh);
  ctx.restore();
  ctx.globalAlpha = 1;
  ctx.textAlign = "left";
}

function drawLowHpVignette(){
  if(!player) return;
  const hpRatio = player.hp / player.maxHp;
  if(hpRatio > 0.35) return;
  const intensity = (0.35 - hpRatio) / 0.35;
  const pulse = 0.5 + Math.sin(tick*0.18)*0.35;
  ctx.save();
  ctx.globalAlpha = intensity * pulse * 0.65;
  const grad = ctx.createRadialGradient(
    canvas.width/2, canvas.height/2, canvas.height*0.25,
    canvas.width/2, canvas.height/2, canvas.height*0.75);
  grad.addColorStop(0, "rgba(255,0,0,0)");
  grad.addColorStop(1, "rgba(255,0,0,1)");
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.restore();
  ctx.globalAlpha = 1;
}

/* ═══════════════════════════════════════════════════════════════════════════
   ATAQUES NORMAIS
   ═══════════════════════════════════════════════════════════════════════════ */
function executeAttack(){
  if(!selectedWeapon) return;
  switch(selectedWeapon.attackType){
    case "melee_arc":    attackMeleeArc(); break;
    case "melee_circle": attackMeleeCircle(); break;
    case "ranged":       attackRanged(); break;
    case "pierce_line":  attackPierceLine(); break;
  }
}

function attackMeleeArc(){
  const angle = getAimAngle();
  const arc = player.attackArc;
  const range = player.attackRange;
  const dmg = player.damage * (1 + ((player.multishot||1)-1)*0.20);
  effects.push({ type:"arcSlash", x:player.x, y:player.y, angle, arc, range,
    life:0.18, maxLife:0.18, color:selectedWeapon.color });
  let anyHit = false;
  for(let i=enemies.length-1;i>=0;i--){
    const e = enemies[i];
    const dx=e.x-player.x, dy=e.y-player.y, dd=Math.hypot(dx,dy);
    if(dd > range+e.r) continue;
    const at = Math.atan2(dy,dx);
    if(Math.abs(normalizeAngle(at-angle)) < arc/2){
      if (e.isBoss && e.invulnerable) continue; 
      e.hp -= dmg;
      applyHitEffects(e,i,dmg);
      anyHit = true;
      if(e.hp<=0) toKill.push(i);
    }
  }
  SoundManager.play(anyHit?'hitEnemy':'melee');
}
function attackMeleeCircle(){
  const range = player.attackRange;
  const dmg = player.damage * (1 + ((player.multishot||1)-1)*0.20);
  effects.push({ type:"ringSlash", x:player.x, y:player.y, range,
    life:0.22, maxLife:0.22, color:selectedWeapon.color });
  let anyHit = false;
  for(let i=enemies.length-1;i>=0;i--){
    const e = enemies[i];
    if(dist2(e,player) < (range+e.r)**2){
        if (e.isBoss && e.invulnerable) continue; 
      e.hp -= dmg;
      applyHitEffects(e,i,dmg);
      anyHit = true;
      if(e.hp<=0) toKill.push(i);
    }
  }
  triggerShake(0.06,3);
  SoundManager.play(anyHit?'hitEnemy':'melee');
}
function attackRanged(){
  const ba = getAimAngle();
  const count = player.multishot||1;
  const spd = selectedWeapon.bulletSpeed, life = player.bulletLife;
  for(let i=0;i<count;i++){
    const a = ba + (i-(count-1)/2)*0.12;
    bullets.push({ x:player.x, y:player.y,
      vx:Math.cos(a)*spd, vy:Math.sin(a)*spd,
      r:6, life, pierce:player.pierce||0, hitCount:0,
      color:selectedWeapon.color, kind:"arrow", angle:a, 
      hitSet: new Set()
    });
  }
  SoundManager.play('shoot');
}
function attackPierceLine(){
  const ba = getAimAngle();
  const count = player.multishot||1;
  const spd = selectedWeapon.bulletSpeed, life = player.bulletLife;
  const basePierce = selectedWeapon.baseBulletPierce||99;
  for(let i=0;i<count;i++){
    const a = ba + (i-(count-1)/2)*0.08;
    bullets.push({ x:player.x, y:player.y,
      vx:Math.cos(a)*spd, vy:Math.sin(a)*spd,
      r:8, life, pierce:basePierce+(player.pierce||0), hitCount:0,
      color:selectedWeapon.color, kind:"spear", angle:a,
      hitSet:new Set() });
  }
  SoundManager.play('shoot');
}

