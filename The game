// Desenha HP como corações estilo Isaac. Cada coração = 20 HP.
// Quebra em linhas quando player tem muita vida (upgrades).
function drawHearts(x, y){
  const hpPerHeart = 20;
  const maxHearts = Math.ceil(player.maxHp / hpPerHeart);
  const heartsPerRow = 10;
  const heartW = 20, heartH = 20, gap = 2;
  const hp = Math.max(0, player.hp);
  for(let i=0;i<maxHearts;i++){
    const row = Math.floor(i / heartsPerRow);
    const col = i % heartsPerRow;
    const hx = x + col*(heartW+gap);
    const hy = y + row*(heartH+gap);
    const remaining = hp - i*hpPerHeart;
    let key;
    if(remaining >= hpPerHeart) key = "heart_full";
    else if(remaining >= hpPerHeart/2) key = "heart_half";
    else if(remaining > 0) key = "heart_half"; // mostra meio para qualquer HP positivo < 10
    else key = "heart_empty";
    drawSprite(key, hx+heartW/2, hy+heartH/2, 2, 1, 0);
  }
}

function drawHUD(){
  const pad=14;
  // corações no lugar da barra de HP
  drawHearts(pad, pad);
  // Quantas linhas de corações existem?
  const rowsHearts = Math.ceil(Math.ceil(player.maxHp/20)/10);
  const heartsBlockH = rowsHearts*22;

  // XP bar
  const xpW=220, xpH=8;
  const xpY = pad + heartsBlockH + 4;
  ctx.fillStyle="#1a0a30"; ctx.fillRect(pad, xpY, xpW, xpH);
  ctx.fillStyle="#AA00FF"; ctx.fillRect(pad, xpY, xpW*(player.xp/(CFG.XP_PER_LEVEL*player.level)), xpH);
  ctx.strokeStyle="#7c3aed"; ctx.lineWidth=1; ctx.strokeRect(pad, xpY, xpW, xpH);
  ctx.fillStyle="#C084FC"; ctx.font="bold 12px Arial";
  ctx.fillText(`Lv.${player.level}`, pad+xpW+8, xpY+8);

  // Especial + arma
  const spReady = specialTimer<=0;
  ctx.fillStyle = spReady ? selectedWeapon.color : "#666";
  ctx.font="13px Arial";
  const spName = selectedWeapon.specialName || "Especial";
  ctx.fillText(spReady ? `[E] ${spName} — PRONTO` : `[E] ${spName} — ${specialTimer.toFixed(1)}s`, pad, xpY+28);

  // Dash/Melee indicadores (se tiver)
  let extraY = xpY+48;
  if(player.hasDash){
    const ready = dashTimer<=0;
    ctx.fillStyle = ready ? "#ffb74d" : "#666";
    ctx.font="12px Arial";
    ctx.fillText(ready ? "[Q] Dash — PRONTO" : `[Q] Dash — ${dashTimer.toFixed(1)}s`, pad, extraY);
    extraY += 16;
  }
  if(player.hasMelee){
    const ready = meleeCdTimer<=0;
    ctx.fillStyle = ready ? "#f44336" : "#666";
    ctx.font="12px Arial";
    ctx.fillText(ready ? "[R] Área — PRONTO" : `[R] Área — ${meleeCdTimer.toFixed(1)}s`, pad, extraY);
    extraY += 16;
  }

  ctx.fillStyle="#AAA"; ctx.font="11px Arial";
  const apm = (60/player.shootCd).toFixed(0);
  ctx.fillText(`${selectedWeapon.name} — ${apm} atq/min | Dano ${Math.round(player.damage)}`, pad, extraY);

  ctx.fillStyle="#FFD700"; ctx.font="bold 15px Arial"; ctx.textAlign="right";
  ctx.fillText(`Wave ${wave}`, canvas.width-pad, pad+14);
  ctx.fillStyle="#CCC"; ctx.fillText(`Score: ${score}`, canvas.width-pad, pad+32);
  ctx.fillText(`Inimigos: ${enemies.length}`, canvas.width-pad, pad+50);
  const wavesToBoss = CFG.BOSS_WAVE_INTERVAL - (wave % CFG.BOSS_WAVE_INTERVAL);
  if(wavesToBoss < CFG.BOSS_WAVE_INTERVAL && wavesToBoss > 0){
    ctx.fillStyle="#FF5252"; ctx.font="bold 12px Arial";
    ctx.fillText(`Boss em ${wavesToBoss} wave${wavesToBoss>1?'s':''}`, canvas.width-pad, pad+68);
  }
  ctx.textAlign="left";

  if(waveCleared() && waveBreakTimer>0){
    ctx.fillStyle="rgba(0,0,0,0.5)"; ctx.fillRect(canvas.width/2-140, canvas.height-50, 280, 36);
    ctx.fillStyle="#FFD700"; ctx.font="bold 16px Arial"; ctx.textAlign="center";
    ctx.fillText(`Próxima wave em ${Math.ceil(waveBreakTimer)}s`, canvas.width/2, canvas.height-28);
    ctx.textAlign="left";
  }
}

