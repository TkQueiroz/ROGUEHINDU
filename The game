function getBossForWave(w){
  if(w % CFG.BOSS_WAVE_INTERVAL !== 0) return null;
  const idx = Math.floor(w / CFG.BOSS_WAVE_INTERVAL) - 1;
  if(idx < 0) return null;
  if(idx < BOSSES.length) return BOSSES[idx];
  // ciclo: boss se repete mas stats escalam
  const cycle = Math.floor(idx / BOSSES.length);
  const base = BOSSES[idx % BOSSES.length];
  const scale = 1 + cycle*0.6;
  return { ...base,
    name: base.name + " — CICLO "+(cycle+1),
    hpMult: base.hpMult * scale,
    dmgMult: base.dmgMult * (1 + cycle*0.3),
    sizeMult: base.sizeMult * (1 + cycle*0.1) };
}

