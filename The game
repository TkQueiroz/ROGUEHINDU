// Enquanto carrega, mostra tela de loading simples
(function showLoadingUntilReady() {
  if (imgsReady) return;
  ctx.fillStyle = '#1a0a06';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = '#DAA520';
  ctx.font = 'bold 28px Arial';
  ctx.textAlign = 'center';
  ctx.fillText('Carregando assets...', canvas.width/2, canvas.height/2);
  ctx.fillText(`${imgsLoaded} / ${imgsTotal}`, canvas.width/2, canvas.height/2 + 40);
  ctx.textAlign = 'left';
  requestAnimationFrame(showLoadingUntilReady);
})();
