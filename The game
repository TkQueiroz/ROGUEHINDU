function takeEnemyType(){
  const avail = ENEMY_TYPES.filter(e=>e.unlockWave<=wave);
  const total = avail.reduce((s,t)=>s+t.weight,0);
  let r = Math.random()*total;
  for(const t of avail){ r-=t.weight; if(r<=0) return t; }
  return avail[0];
}

function spawnWave(){
  wave++;
  if(wave>25){
    const extra=wave-25;
    CFG.WAVE_BREAK=0.5; 
    CFG.ENEMY_SPAWN_DIST=Math.max(100, BASE_CFG.ENEMY_SPAWN_DIST-15*extra);
    CFG.ENEMY_SPEED=BASE_CFG.ENEMY_SPEED*(extra*0.15+1); 
    CFG.ENEMY_DAMAGE=BASE_CFG.ENEMY_DAMAGE*(extra*0.15+1);  
    player.hurtTimer=Math.max(0.12, 0.7-extra*0.05)
  }
  const bossData = getBossForWave(wave);
  if(bossData){ spawnBossWave(bossData); return; }
  // wave normal
  const count = CFG.WAVE_BASE_COUNT + (wave-1)*CFG.WAVE_COUNT_GROW;
  const base = 1 + (wave-1)*CFG.WAVE_HP_SCALE;
  const baseSpdMult = 1 + (wave-1)*CFG.WAVE_SPEED_SCALE;
  const diff = getDifficultyModifiers();
  const ps = getPlayerScaleFactor();
  for(let i=0;i<count;i++){
    const type = takeEnemyType();
    const angle = Math.random()*Math.PI*2;
    const dist = CFG.ENEMY_SPAWN_DIST + Math.random()*100;
    const ex = clamp(player.x+Math.cos(angle)*dist, CFG.WALL_THICKNESS+20, CFG.ARENA_W-CFG.WALL_THICKNESS-20);
    const ey = clamp(player.y+Math.sin(angle)*dist, CFG.WALL_THICKNESS+20, CFG.ARENA_H-CFG.WALL_THICKNESS-20);
    const hp = CFG.ENEMY_HP*type.hpMult*diff.hpMult*ps;
    enemies.push({
      x:ex, y:ey, hp, maxHp:hp,
      speed: CFG.ENEMY_SPEED*type.spdMult*baseSpdMult*diff.spdMult,
      color:type.color, name:type.name, sprite:type.sprite, behavior:type.behavior,
      r: CFG.ENEMY_RADIUS*(type.sizeMult||1),
      hurtTimer:0, burnTimer:0, facing:1, animFrame:0,
      shootTimer: type.behavior==="ranged" ? 1.5+Math.random() : 0
    });
  }
}

function spawnBossWave(bd){
  const diff = getDifficultyModifiers();
  const ps = getPlayerScaleFactor();
  const waveScale = 1 + (wave-1)*CFG.WAVE_HP_SCALE*0.5;
  const hp = CFG.ENEMY_HP * bd.hpMult * waveScale * diff.hpMult * ps;
  // spawn longe do player
  const angle = Math.random()*Math.PI*2;
  const dist = CFG.ENEMY_SPAWN_DIST+200;
  const ex = clamp(player.x+Math.cos(angle)*dist, CFG.WALL_THICKNESS+100, CFG.ARENA_W-CFG.WALL_THICKNESS-100);
  const ey = clamp(player.y+Math.sin(angle)*dist, CFG.WALL_THICKNESS+100, CFG.ARENA_H-CFG.WALL_THICKNESS-100);
  enemies.push({
    x:ex, y:ey, hp, maxHp:hp,
    speed: CFG.ENEMY_SPEED*bd.spdMult*diff.spdMult,
    color:bd.color, name:bd.name, sprite:bd.sprite, behavior:bd.behavior,
    r: CFG.ENEMY_RADIUS*bd.sizeMult,
    hurtTimer:0, burnTimer:0, facing:1, animFrame:0,
    isBoss:true, bossData:bd,
    dmgMult: bd.dmgMult,
    bTimer:0, phase3Forced: false
  });
  // intro
  bossIntroData = bd;
  bossIntroTimer = 3.5;
  SoundManager.play('special');
  triggerShake(0.8, 18);
}

function waveCleared(){ return enemies.length===0; }

function killEnemy(idx){
  const e = enemies[idx];
  if(!e) return; 
  if(e.isTotem){
     enemies.splice(idx,1);
      spawnParticles(e.x, e.y, "#eab308", 30);
      return; 
  }
  const reward = e.isBoss ? 800 : 100;
  score += reward*difficultiesMultiplier[difficulty];
  addCombo();
  // dropa orbes de XP em vez de dar XP direto — player precisa coletar
  const xpVal = e.isBoss ? CFG.BOSS_XP_REWARD : CFG.ENEMY_XP;
  const orbCount = e.isBoss ? 10 : Math.min(5, Math.max(1, Math.ceil(xpVal/15)));
  for(let i=0;i<orbCount;i++) spawnXpOrb(e.x, e.y, xpVal/orbCount);
  // flash branco de morte + partículas do tipo
  spawnParticles(e.x, e.y, e.color, e.isBoss ? 80 : CFG.PARTICLE_COUNT*2);
  spawnParticles(e.x, e.y, "#ffffff", e.isBoss ? 30 : 10);
  if(e.isBoss){
    triggerShake(1.2, 20);
    SoundManager.play('waveClear');
    for(let i=0;i<6;i++){
      setTimeout(()=>{
        spawnParticles(e.x+(Math.random()-0.5)*80, e.y+(Math.random()-0.5)*80, "#FFD700", 30);
      }, i*100);
    }
  }
  if(player.explode){
  for (let i = 0; i < enemies.length; i++) {
    if (i === idx) continue;
    if (dist2(e, enemies[i]) < 100 ** 2) {
      const other = enemies[i];
      other.hp = Math.max(0, other.hp - 50);
      spawnDamageNumber(other.x, other.y, 50, "#FF5722");
      if (other.hp <= 0 && !other._queued) {
        other._queued = true;
        toKill.push(i);          // guarda o índice
      }
    }
  }
  spawnParticles(e.x, e.y, "#FF5722", 30);
  }
  enemies.splice(idx,1);
}

function showUpgrades(){
  state = STATES.UPGRADE;
  upgradeChoices = [];
  const pool = [...currentPowerups];
  for(let i=0;i<3 && pool.length;i++){
    const r = Math.floor(Math.random()*pool.length);
    upgradeChoices.push(pool[r]); pool.splice(r,1);
  }
  upgradeSelectedIndex = 0;
}
function applyUpgrade(idx){
  const up = upgradeChoices[idx];
  up.apply(player);
  SoundManager.play('powerup');
  if(up.once){
    const i = currentPowerups.findIndex(p=>p.id===up.id);
    if(i!==-1) currentPowerups.splice(i,1);
  }
  resetInputs(); 
  state = STATES.PLAYING;
  waveBreakTimer = CFG.WAVE_BREAK;
}
function levelUpUpgrade(){ if(state===STATES.PLAYING) showUpgrades(); }

